---
/**
 * ABTEILUNG83 - Pure Black Terminal Signature + Glitch Effect
 * "Less Noise. Nice Data. No Bloat."
 */
const gitHash = import.meta.env.PUBLIC_GIT_HASH || 'void';
const buildDate = new Date().toLocaleDateString('de-AT', { 
  year: '2-digit', month: '2-digit', day: '2-digit', hour: '2-digit', minute: '2-digit' 
});
---

<div class="sig-wrapper">
  <div class="sig-container">
    <div class="sig-flex">
      <div class="sig-left-group">
        <div id="ab83-trigger" class="sig-trigger">
          <span class="pulse-arrow">❯</span>
          <span class="trigger-text">./ab83_init --status</span>
        </div>
        <div class="sig-meta-item">
          <span class="sig-label">hash:</span>
          <span class="sig-value">{gitHash}</span>
        </div>
        <div class="sig-meta-item">
          <span class="sig-label">build:</span>
          <span class="sig-value">{buildDate}</span>
        </div>
      </div>

      <div class="sig-right-group">
        <a 
          href="https://abteilung83.at" 
          target="_blank" 
          id="glitch-link"
          data-value="ABTEILUNG83"
          rel="noopener noreferrer"
          class="glitch-link"
        >
          Architects
        </a>
        <span class="sig-divider" aria-hidden="true">/</span>
        <a href="https://astro.build" target="_blank" rel="noopener noreferrer" class="astro-link">
          ASTRO_CORE
        </a>
      </div>
    </div>
  </div>
</div>

<style>
  .sig-wrapper {
    width: 100%;
    background-color: #000000;
    padding: 1rem 0;
    border-top: 1px solid #18181b;
    user-select: none;
    overflow: hidden;
  }

  .sig-container {
    width: 100%;
    max-width: 1000px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .sig-flex {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.5rem;
    text-align: left;
    font-family: monospace;
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .sig-left-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    width: 100%;
  }

  .sig-trigger {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    cursor: crosshair;
    text-decoration: none;
  }

  .pulse-arrow {
    color: #10b981;
    font-weight: 900;
    animation: pulse-animation 2s infinite;
    transition: color 0.2s;
  }

  .trigger-text {
    color: #52525b;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    transition: color 0.2s;
  }

  .sig-trigger:hover .trigger-text {
    color: #d4d4d8;
  }

  .sig-trigger:hover .pulse-arrow {
    color: #ffffff;
  }

  .sig-meta-item {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .sig-label {
    color: #3f3f46;
  }

  .sig-value {
    color: #71717a;
  }

  .sig-right-group {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    width: 100%;
    text-align: center;
  }

  .glitch-link {
    color: #10b981;
    font-weight: bold;
    letter-spacing: 0.15em;
    transition: color 0.2s;
    display: inline-block;
    min-width: 11ch;
    text-decoration: none;
  }

  .glitch-link:hover {
    color: #34d399;
  }

  .sig-divider {
    color: #27272a;
    margin-left: -0.75rem;
  }

  .astro-link {
    color: #71717a;
    text-decoration: none;
    font-size: 9px;
    transition: color 0.2s;
  }

  .astro-link:hover {
    color: #f97316;
  }

  @keyframes pulse-animation {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }

  @media (min-width: 768px) {
    .sig-flex {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      gap: 1.5rem;
    }

    .sig-left-group {
      flex-direction: row;
      align-items: center;
      gap: 1.5rem;
      width: auto;
      flex: 1;
    }

    .sig-right-group {
      width: auto;
      flex-shrink: 0;
      justify-content: flex-end;
      text-align: left;
    }
  }
</style>

<script>
  // --- Glitch Logic ---
  const letters = "ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789@#$%&";
  const glitchLink = document.getElementById('glitch-link');
  let interval = null;

  glitchLink?.addEventListener('mouseenter', (event) => {
    let iteration = 0;
    const target = event.target;
    const originalText = "Architects";
    const newText = target.dataset.value;

    clearInterval(interval);

    interval = setInterval(() => {
      target.innerText = newText
        .split("")
        .map((letter, index) => {
          if (index < iteration) {
            return newText[index];
          }
          return letters[Math.floor(Math.random() * 26)];
        })
        .join("");

      if (iteration >= newText.length) {
        clearInterval(interval);
      }

      iteration += 1 / 3;
    }, 30);
  });

  // Reset to original
  glitchLink?.addEventListener('mouseleave', (event) => {
    clearInterval(interval);
    event.target.innerText = "Architects";
  });

  // --- Console Easter Egg (from previous) ---
  const trigger = document.getElementById('ab83-trigger');
  trigger?.addEventListener('click', () => {
    console.clear();
    console.log("%c❯ SYSTEM_CHECK: ABTEILUNG83 CORE ONLINE", "color: #10b981; font-weight: bold; font-family: monospace;");
    console.table({
      architect: "ABTEILUNG83",
      status: "Stable",
      glitch_module: "Active"
    });
  });
</script>
