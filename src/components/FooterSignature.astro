---
/**
 * ABTEILUNG83 - Pure Black Terminal Signature + Glitch Effect
 * "Less Noise. Nice Data. No Bloat."
 */
const gitHash = import.meta.env.PUBLIC_GIT_HASH || 'void';
const buildDate = new Date().toLocaleDateString('de-AT', { 
  year: '2-digit', month: '2-digit', day: '2-digit', hour: '2-digit', minute: '2-digit' 
});
---

<div class="w-full bg-[#000000] py-4 border-t border-zinc-900 select-none overflow-hidden">
  <div class="container mx-auto px-1">
    <div class="flex flex-col items-start gap-2 text-left font-mono text-[10px] tracking-[0.1em] uppercase md:flex-row md:items-center md:justify-between md:gap-6">
      <div class="grid w-full grid-cols-[minmax(0,1.6fr)_auto_auto] items-center gap-x-4 gap-y-1 text-zinc-700 md:flex md:w-auto md:flex-1 md:flex-wrap md:items-center md:gap-x-4 md:gap-y-1">
        <div id="ab83-trigger" class="flex min-w-0 items-center gap-2 cursor-crosshair group">
          <span class="text-emerald-500 font-black animate-pulse group-hover:text-white transition-colors">❯</span>
          <span class="truncate text-zinc-600 group-hover:text-zinc-300 transition-colors">./ab83_init --status</span>
        </div>
        <div class="flex items-center justify-end gap-1 md:justify-start">
          <span class="opacity-50">hash:</span>
          <span class="text-zinc-500">{gitHash}</span>
        </div>
        <div class="flex items-center justify-end gap-1 md:justify-start">
          <span class="opacity-50">build:</span>
          <span class="text-zinc-500">{buildDate}</span>
        </div>
      </div>

      <div class="flex w-full items-center justify-center gap-4 text-center md:w-auto md:shrink-0 md:justify-end md:text-left">
        <a 
          href="https://abteilung83.at" 
          target="_blank" 
          id="glitch-link"
          data-value="ABTEILUNG83"
          rel="noopener noreferrer"
          class="text-emerald-500 font-bold tracking-widest transition-colors inline-block min-w-[11ch]"
        >
          Architects
        </a>
        <span class="text-zinc-800 -ml-3" aria-hidden="true">/</span>
        <a href="https://astro.build" target="_blank" rel="noopener noreferrer" class="text-zinc-500 hover:text-orange-500 transition-colors text-[9px]">
          ASTRO_CORE
        </a>
      </div>

    </div>
  </div>
</div>

<script>
  // --- Glitch Logic ---
  const letters = "ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789@#$%&";
  const glitchLink = document.getElementById('glitch-link');
  let interval = null;

  glitchLink?.addEventListener('mouseenter', (event) => {
    let iteration = 0;
    const target = event.target;
    const originalText = "Architects";
    const newText = target.dataset.value;

    clearInterval(interval);

    interval = setInterval(() => {
      target.innerText = newText
        .split("")
        .map((letter, index) => {
          if (index < iteration) {
            return newText[index];
          }
          return letters[Math.floor(Math.random() * 26)];
        })
        .join("");

      if (iteration >= newText.length) {
        clearInterval(interval);
      }

      iteration += 1 / 3;
    }, 30);
  });

  // Reset to original
  glitchLink?.addEventListener('mouseleave', (event) => {
    clearInterval(interval);
    event.target.innerText = "Architects";
  });

  // --- Console Easter Egg (from previous) ---
  const trigger = document.getElementById('ab83-trigger');
  trigger?.addEventListener('click', () => {
    console.clear();
    console.log("%c❯ SYSTEM_CHECK: ABTEILUNG83 CORE ONLINE", "color: #10b981; font-weight: bold; font-family: monospace;");
    console.table({
      architect: "ABTEILUNG83",
      status: "Stable",
      glitch_module: "Active"
    });
  });
</script>
