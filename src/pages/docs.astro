	<script is:inline>
		// Language configuration
		function updateLang(lang) {
			document.documentElement.setAttribute('lang', lang);
			localStorage.setItem('preferred-lang', lang);
		}

		// Detect language
		const savedLang = localStorage.getItem('preferred-lang');
		const browserLang = (navigator.language || navigator.userLanguage).startsWith('de') ? 'de' : 'en';
		const initialLang = savedLang || browserLang;
		updateLang(initialLang);

		document.addEventListener('DOMContentLoaded', () => {
			// Setup toggle button
			const btn = document.getElementById('lang-toggle');
			if (btn) {
				btn.addEventListener('click', () => {
					const current = document.documentElement.getAttribute('lang') || 'en';
					const next = current === 'en' ? 'de' : 'en';
					updateLang(next);
				});
			}

			// Setup mobile nav toggle
			const navToggle = document.getElementById('mobile-nav-toggle');
			const mainNav = document.getElementById('main-nav');
			if (navToggle && mainNav) {
				const closeNav = () => {
					mainNav.classList.remove('nav-open');
					navToggle.setAttribute('aria-expanded', 'false');
				};
				navToggle.addEventListener('click', (e) => {
					e.stopPropagation();
					const isOpen = mainNav.classList.toggle('nav-open');
					navToggle.setAttribute('aria-expanded', String(isOpen));
				});
				mainNav.addEventListener('click', (e) => {
					if (e.target.closest && e.target.closest('a')) closeNav();
				});
				document.addEventListener('click', (e) => {
					if (!mainNav.contains(e.target) && !navToggle.contains(e.target)) closeNav();
				});
				document.addEventListener('keydown', (e) => {
					if (e.key === 'Escape') closeNav();
				});
			}

			// Split README content into en/de sections dynamically
			const introSec = document.getElementById('doc-introduction');
			if (introSec) {
				const contentDiv = introSec.querySelector('.markdown-content');
				if (contentDiv) {
					const headers = Array.from(contentDiv.querySelectorAll('h2'));
					const enHeader = headers.find(h => h.textContent.includes('English'));
					const deHeader = headers.find(h => h.textContent.includes('Deutsche') || h.textContent.includes('Deutsch'));
					
					if (enHeader && deHeader) {
						const enWrapper = document.createElement('div');
						enWrapper.className = 'lang-en';
						const deWrapper = document.createElement('div');
						deWrapper.className = 'lang-de';
						
						let currentWrapper = enWrapper;
						let node = enHeader.nextSibling;
						while (node) {
							const nextNode = node.nextSibling;
							if (node === deHeader) {
								currentWrapper = deWrapper;
								node = nextNode;
								continue;
							}
							currentWrapper.appendChild(node);
							node = nextNode;
						}
						
						contentDiv.innerHTML = '';
						contentDiv.appendChild(enWrapper);
						contentDiv.appendChild(deWrapper);
					}
				}
			}
		});
	</script>
