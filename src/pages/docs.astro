		left: 0;
		width: 100%;
		background: rgba(8, 9, 11, 0.95);
		backdrop-filter: blur(12px);
		border-bottom: 1px solid var(--border);
		padding: 0.75rem 1.5rem;
		z-index: 50;
		align-items: center;
		gap: 1rem;
	}

	.menu-toggle-btn {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		background: rgba(255, 255, 255, 0.05);
		border: 1px solid var(--border);
		color: var(--text-primary);
		padding: 0.4rem 0.8rem;
		border-radius: 6px;
		font-size: 0.85rem;
		cursor: pointer;
	}

	.mobile-doc-title {
		font-family: var(--font-heading);
		font-weight: 600;
		font-size: 0.95rem;
		color: var(--text-primary);
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
	}

	/* Scroll to top button */
	.back-to-top {
		position: fixed;
		bottom: 2rem;
		right: 2rem;
		background: var(--bg-tertiary);
		border: 1px solid var(--border);
		color: var(--text-primary);
		width: 40px;
		height: 40px;
		border-radius: 50%;
		font-size: 1.2rem;
		cursor: pointer;
		display: flex;
		align-items: center;
		justify-content: center;
		opacity: 0;
		visibility: hidden;
		transition: var(--transition);
		z-index: 100;
		box-shadow: var(--shadow-md);
	}

	.back-to-top.visible {
		opacity: 1;
		visibility: visible;
	}

	.back-to-top:hover {
		border-color: var(--accent);
		background: var(--accent);
		color: #fff;
		transform: translateY(-2px);
	}

	/* Responsive breakpoints */
	@media (max-width: 1024px) {
		.docs-layout {
			grid-template-columns: 1fr;
			gap: 1.5rem;
		}

		.docs-outline {
			display: none;
		}

		.mobile-docs-bar {
			display: flex;
		}

		.docs-sidebar {
			position: fixed;
			top: 130px;
			left: -280px;
			width: 280px;
			height: calc(100vh - 130px);
			background: var(--bg-primary);
			border-right: 1px solid var(--border);
			padding: 1.5rem;
			z-index: 40;
			transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
		}

		.docs-sidebar.open {
			transform: translateX(280px);
		}

		.docs-wrapper {
			padding-top: 80px;
		}
	}
</style>

<script>
	// Handle client side logic for active documents, sidebar filtering, and dynamic table of contents.
	document.addEventListener("DOMContentLoaded", () => {
		const navItems = document.querySelectorAll(".nav-item");
		const docSections = document.querySelectorAll(".doc-section");
		const tocList = document.getElementById("toc-list");
		const sidebar = document.getElementById("docs-sidebar");
		const sidebarToggleBtn = document.getElementById("sidebar-toggle");
		const mobileDocTitle = document.querySelector(".mobile-doc-title");

		// --- 1. Navigation / Tab Switching ---
		function showDoc(docId) {
			// Remove active class from buttons & sections
			navItems.forEach(item => {
				if (item.getAttribute("data-doc") === docId) {
					item.classList.add("active");
					// Update mobile title (use only the currently active language span)
					if (mobileDocTitle) {
						const currentLang = document.documentElement.getAttribute("lang") || "en";
						const langSpan = item.querySelector(`.lang-${currentLang}`);
						mobileDocTitle.textContent = langSpan ? langSpan.textContent : item.textContent;
					}
				} else {
					item.classList.remove("active");
				}
			});

			docSections.forEach(section => {
				if (section.id === `doc-${docId}`) {
					section.classList.add("active");
					// Regenerate Table of Contents
					generateTOC(section);
				} else {
					section.classList.remove("active");
				}
			});

			// On mobile, close sidebar automatically
			if (sidebar && sidebar.classList.contains("open")) {
				sidebar.classList.remove("open");
			}

			// Scroll back to top of document content
			window.scrollTo({ top: 0, behavior: "smooth" });
		}

		// Initial document load by Hash or default to introduction
		function loadInitialDoc() {
			const hash = window.location.hash.substring(1);
			const validDocs = Array.from(navItems).map(item => item.getAttribute("data-doc"));
			if (hash && validDocs.includes(hash)) {
				showDoc(hash);
			} else {
				showDoc("introduction");
			}
		}

		// Setup event listeners for sidebar click
		navItems.forEach(item => {
			item.addEventListener("click", () => {
				const docId = item.getAttribute("data-doc");
				if (docId) {
					window.location.hash = docId;
					showDoc(docId);
				}
			});
		});

		// Listen to hash change
		window.addEventListener("hashchange", () => {
			const hash = window.location.hash.substring(1);
			if (hash) {
				const docButton = document.querySelector(`.nav-item[data-doc="${hash}"]`);
				if (docButton) {
					showDoc(hash);
				}
			}
		});

		// --- 2. Dynamic Table of Contents (ToC) ---
		function generateTOC(activeSection) {
			if (!tocList) return;
			tocList.innerHTML = "";

			const headings = activeSection.querySelectorAll("h2, h3");
			if (headings.length === 0) {
				const emptyLi = document.createElement("li");
				emptyLi.className = "outline-link text-muted";
				emptyLi.style.fontSize = "0.8rem";
				emptyLi.textContent = "No sections on this page";
				tocList.appendChild(emptyLi);
				return;
			}

			headings.forEach((heading, index) => {
				const text = heading.textContent || "";
				// Ensure heading has an ID
				let id = heading.id;
				if (!id) {
					id = text.toLowerCase()
						.replace(/[^a-z0-9]+/g, "-")
						.replace(/(^-|-$)/g, "");
					heading.id = `${activeSection.id}-${id}-${index}`;
				}

				const li = document.createElement("li");
				const button = document.createElement("button");
				button.className = `outline-link ${heading.tagName.toLowerCase() === "h3" ? "indent-3" : ""}`;
				button.style.background = "none";
				button.style.border = "none";
				button.style.textAlign = "left";
				button.style.fontFamily = "inherit";
				button.textContent = text;
				
				button.addEventListener("click", () => {
					const el = document.getElementById(heading.id);
					if (el) {
						const offset = 140; // Space for floating headers
						const elementPosition = el.getBoundingClientRect().top;
						const offsetPosition = elementPosition + window.pageYOffset - offset;
						window.scrollTo({
							top: offsetPosition,
							behavior: "smooth"
						});
					}
				});

				li.appendChild(button);
				tocList.appendChild(li);
			});
		}

		// --- 3. Mobile Sidebar Toggle ---
		if (sidebarToggleBtn && sidebar) {
			sidebarToggleBtn.addEventListener("click", (e) => {
				e.stopPropagation();
				sidebar.classList.toggle("open");
			});

			// Close sidebar when clicking outside
			document.addEventListener("click", (e) => {
				if (sidebar.classList.contains("open") && !sidebar.contains(e.target as Node) && e.target !== sidebarToggleBtn) {
					sidebar.classList.remove("open");
				}
			});
		}

		// --- 4. Sidebar Search Filter ---
		const searchInput = document.getElementById("docs-search") as HTMLInputElement;
		const searchClearBtn = document.getElementById("search-clear");
		const navGroups = document.querySelectorAll(".nav-group");

		if (searchInput) {
			searchInput.addEventListener("input", (e) => {
				const query = (e.target as HTMLInputElement).value.toLowerCase().trim();

				if (query) {
					searchClearBtn?.classList.add("visible");
				} else {
					searchClearBtn?.classList.remove("visible");
				}

				navGroups.forEach(group => {
					let visibleInGroup = 0;
					const groupItems = group.querySelectorAll(".nav-item");

					groupItems.forEach(item => {
						const text = item.textContent?.toLowerCase() || "";
						if (text.includes(query)) {
							item.classList.remove("hide");
							visibleInGroup++;
						} else {
							item.classList.add("hide");
						}
					});

					if (visibleInGroup > 0) {
						group.classList.remove("hide");
					} else {
						group.classList.add("hide");
					}
				});
			});

			searchClearBtn?.addEventListener("click", () => {
				searchInput.value = "";
				searchClearBtn.classList.remove("visible");
				searchInput.dispatchEvent(new Event("input"));
				searchInput.focus();
			});
		}

		// --- 5. Code Enhancements (Copy Buttons, Window Frames, Alert Formatting) ---
		function enhanceCodeBlocks() {
			const preElements = document.querySelectorAll(".markdown-content pre");

			preElements.forEach(pre => {
				// Prevent double wrapping
				if (pre.parentElement?.classList.contains("terminal-wrapper")) return;

				// Create terminal container
				const wrapper = document.createElement("div");
				wrapper.className = "terminal-wrapper";

				// Create terminal header bar
				const header = document.createElement("div");
				header.className = "terminal-decor-header";
				header.innerHTML = `
					<div class="terminal-decor-dots">
						<span class="terminal-decor-dot red"></span>
						<span class="terminal-decor-dot yellow"></span>
						<span class="terminal-decor-dot green"></span>
					</div>
					<div class="terminal-decor-title">${pre.getAttribute("data-lang") || "terminal"}</div>
					<button class="terminal-copy-btn">Copy</button>
				`;

				// Put pre inside wrapper
				pre.parentNode?.insertBefore(wrapper, pre);
				wrapper.appendChild(header);
				wrapper.appendChild(pre);

				// Copy logic
				const copyBtn = header.querySelector(".terminal-copy-btn");
				copyBtn?.addEventListener("click", () => {
					const codeContent = pre.querySelector("code")?.textContent || "";
					navigator.clipboard.writeText(codeContent).then(() => {
						copyBtn.textContent = "Copied!";
						copyBtn.style.color = "var(--success)";
						setTimeout(() => {
							copyBtn.textContent = "Copy";
							copyBtn.style.color = "";
						}, 2000);
					}).catch(err => {
						console.error("Could not copy text: ", err);
					});
				});
			});
		}

		// Convert GitHub style blockquote alerts to beautiful custom Callout divs
		function enhanceAlerts() {
			const blockquotes = document.querySelectorAll(".markdown-content blockquote");

			blockquotes.forEach(bq => {
				const paragraph = bq.querySelector("p");
				if (!paragraph) return;

				const text = paragraph.innerHTML || "";
				let type = "";
				let titleText = "";
				let cleanedText = text;

				if (text.startsWith("[!IMPORTANT]") || text.startsWith("[!WARNING]")) {
					type = "important";
					titleText = "Important";
					cleanedText = text.replace(/^\[!(IMPORTANT|WARNING)\]\s*(<br>)?\s*/i, "");
				} else if (text.startsWith("[!NOTE]")) {
					type = "note";
					titleText = "Note";
					cleanedText = text.replace(/^\[!NOTE\]\s*(<br>)?\s*/i, "");
				} else if (text.startsWith("[!TIP]")) {
					type = "tip";
					titleText = "Pro-Tip";
					cleanedText = text.replace(/^\[!TIP\]\s*(<br>)?\s*/i, "");
				}

				if (type) {
					const callout = document.createElement("div");
					callout.className = `callout ${type}`;
					callout.innerHTML = `<strong>${titleText}:</strong> ${cleanedText}`;
					bq.parentNode?.replaceChild(callout, bq);
				}
			});
		}

		// --- 6. Scroll-To-Top Control ---
		const backToTopBtn = document.getElementById("back-to-top");
		window.addEventListener("scroll", () => {
			if (window.scrollY > 400) {
				backToTopBtn?.classList.add("visible");
			} else {
				backToTopBtn?.classList.remove("visible");
			}
		});

		backToTopBtn?.addEventListener("click", () => {
			window.scrollTo({ top: 0, behavior: "smooth" });
		});

		// Trigger enhancements & initial loading
		enhanceCodeBlocks();
		enhanceAlerts();
		loadInitialDoc();
	});
</script>
