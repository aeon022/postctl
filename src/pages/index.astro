---
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<!-- Navigation Header -->
	<header class="header">
		<div class="container header-container">
			<div class="logo">
				<span class="logo-icon">&gt;_</span>
				<span class="logo-text">postctl</span>
			</div>
			<nav class="nav">
				<a href="#features" class="nav-link">Features</a>
				<a href="#tui-demo" class="nav-link">TUI-Demo</a>
				<a href="#pricing" class="nav-link">Preise & Pro</a>
				<a href="https://github.com/aeon022/postctl" target="_blank" rel="noopener noreferrer" class="nav-link github-link">
					<svg height="20" viewBox="0 0 16 16" width="20" class="github-icon"><path fill="currentColor" d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"></path></svg>
					GitHub
				</a>
			</nav>
		</div>
	</header>

	<main>
		<!-- Hero Section -->
		<section class="hero-section">
			<div class="container hero-container">
				<div class="hero-content">
					<div class="badge">Astro v6 Powered</div>
					<h1 class="hero-title">Social Media Management direkt aus dem <span class="text-gradient">Terminal</span></h1>
					<p class="hero-subtitle">
						Markdown-First, Terminal-Native und AI-Ready. Verwalte und veröffentliche deine Posts für Twitter/X, LinkedIn und Threads, ohne deine Entwicklungsumgebung zu verlassen.
					</p>
					<div class="hero-ctas">
						<a href="#tui-demo" class="btn btn-primary">TUI-Demo ansehen</a>
						<a href="#pricing" class="btn btn-secondary">Pro freischalten</a>
						<a href="https://polar.sh/aeon022/donate" target="_blank" rel="noopener noreferrer" class="btn btn-tertiary">
							<span class="heart-icon">♥</span> Spenden via Polar.sh
						</a>
					</div>
				</div>
				
				<!-- Interactive Terminal Emulator -->
				<div class="hero-terminal">
					<div class="terminal-header">
						<div class="terminal-dots">
							<span class="dot dot-red"></span>
							<span class="dot dot-yellow"></span>
							<span class="dot dot-green"></span>
						</div>
						<div class="terminal-title">bash - postctl --help</div>
					</div>
					<div class="terminal-body" id="typing-terminal">
						<span class="terminal-prompt">$</span> <span class="typed-text"></span><span class="cursor-blink">|</span>
						<pre class="terminal-output hide"></pre>
					</div>
				</div>
			</div>
		</section>

		<!-- Features Grid Section -->
		<section id="features" class="features-section">
			<div class="container">
				<div class="section-header">
					<h2 class="section-title">Entwickelt für effiziente Workflows</h2>
					<p class="section-subtitle">postctl verbindet das Beste aus Git-Versionierung, Terminal-Effizienz und KI-Automatisierung.</p>
				</div>

				<div class="features-grid">
					<!-- Feature 1 -->
					<div class="feature-card">
						<div class="feature-icon">📝</div>
						<h3 class="feature-title">Markdown-First</h3>
						<p class="feature-desc">Deine Posts leben als einfache Markdown-Dateien mit YAML-Frontmatter direkt in deinem Git-Repository. Versioniert, diffbar und per Pull Request reviewbar.</p>
					</div>
					<!-- Feature 2 -->
					<div class="feature-card">
						<div class="feature-icon">🖥️</div>
						<h3 class="feature-title">Terminal-Native</h3>
						<p class="feature-desc">Vollständige TUI (Terminal User Interface) basierend auf Bubbletea. Plane Beiträge, prüfe den Verlauf und editiere Einstellungen, ohne jemals den Browser zu öffnen.</p>
					</div>
					<!-- Feature 3 -->
					<div class="feature-card">
						<div class="feature-icon">🤖</div>
						<h3 class="feature-title">AI-as-Operator</h3>
						<p class="feature-desc">Entwickelt für KI-Agenten (wie Claude oder GPT). CLI-Befehle unterstützen strukturiertes JSON-Output (`--format json`) und simulationssichere Testläufe (`--dry-run`).</p>
					</div>
					<!-- Feature 4 -->
					<div class="feature-card">
						<div class="feature-icon">⚡</div>
						<h3 class="feature-title">Single Binary</h3>
						<p class="feature-desc">Geschrieben in purem Go mit SQLite als integrierter lokaler Datenbank. Keine Node-Runtimes, Docker-Container oder Cloud-Zwang. Ein Binary, läuft überall offline.</p>
					</div>
				</div>
			</div>
		</section>

		<!-- Interactive TUI Simulator Section -->
		<section id="tui-demo" class="tui-section">
			<div class="container">
				<div class="section-header">
					<h2 class="section-title">Erlebe die TUI im Browser</h2>
					<p class="section-subtitle">Klicke durch die Tabs der interaktiven Terminal-Simulation, um postctl in Aktion zu sehen.</p>
				</div>

				<!-- TUI Mockup Container -->
				<div class="tui-emulator">
					<div class="tui-emulator-header">
						<span class="tui-emulator-title">postctl — Terminal User Interface</span>
					</div>
					
					<!-- Interactive TUI Application -->
					<div class="tui-app">
						<!-- Title Bar -->
						<div class="tui-title-bar">postctl — Social Media CLI</div>
						
						<!-- Tabs Navigation -->
						<div class="tui-tabs">
							<button class="tui-tab active" data-tab="0">● Dashboard</button>
							<button class="tui-tab" data-tab="1">◷ Posts</button>
							<button class="tui-tab" data-tab="2">↺ Schedule</button>
							<button class="tui-tab" data-tab="3">⚙ Settings</button>
						</div>
						
						<!-- TUI Tab Contents -->
						<div class="tui-content-area">
							<!-- Tab 0: Dashboard -->
							<div class="tui-tab-content active" id="tui-tab-0">
								<div class="dashboard-grid">
									<div class="dashboard-col">
										<div class="tui-sub-header">CAMPAIGNS</div>
										<ul class="tui-list">
											<li><span class="color-accent">●</span> orbiter-v0365 <span class="tui-muted">(5 posts, 2 posted)</span></li>
											<li><span class="color-accent">●</span> dual-render <span class="tui-muted">(9 posts, 0 posted)</span></li>
										</ul>
										
										<div class="tui-sub-header" style="margin-top: 1.5rem;">NEXT UP</div>
										<ul class="tui-list">
											<li><span class="color-posted">◷</span> Mon 09:00 - Twitter EN</li>
											<li><span class="color-posted">◷</span> Mon 14:00 - Threads EN</li>
											<li><span class="color-posted">◷</span> Tue 09:00 - LinkedIn DE</li>
										</ul>
									</div>
									<div class="dashboard-col border-left">
										<div class="tui-sub-header">STATS</div>
										<table class="stats-table">
											<tr><td>Posted:</td><td class="color-posted align-right">12</td></tr>
											<tr><td>Scheduled:</td><td class="color-accent align-right">8</td></tr>
											<tr><td>Drafts:</td><td class="color-muted align-right">5</td></tr>
											<tr><td>Failed:</td><td class="color-failed align-right">0</td></tr>
										</table>
										
										<div class="tui-sub-header" style="margin-top: 1.5rem;">PLATFORMS</div>
										<ul class="tui-list platform-status">
											<li><span class="status-indicator active">✓</span> Twitter/X <span class="tui-muted">(connected)</span></li>
											<li><span class="status-indicator active">✓</span> LinkedIn <span class="tui-muted">(connected)</span></li>
											<li><span class="status-indicator inactive">○</span> Threads <span class="tui-muted">(not auth'd)</span></li>
										</ul>
									</div>
								</div>
							</div>
							
							<!-- Tab 1: Posts -->
							<div class="tui-tab-content" id="tui-tab-1">
								<div class="tui-sub-header">IMPORTIERTE BEITRÄGE (FILTER: ALL)</div>
								<div class="posts-list">
									<div class="post-item selected">
										<div class="post-header">
											<span class="post-campaign">orbiter-v0365 / Twitter EN</span>
											<span class="post-date color-accent">◷ Mon 09:00</span>
										</div>
										<div class="post-snippet">"Your CMS is a single file. No database server. No Docker..."</div>
										<div class="post-meta tui-muted">thread · 5 tweets · 📎 2 images</div>
									</div>
									<div class="post-item">
										<div class="post-header">
											<span class="post-campaign">orbiter-v0365 / LinkedIn EN</span>
											<span class="post-date color-accent">◷ Wed 09:00</span>
										</div>
										<div class="post-snippet">"Shipped: Calendar view, cross-pod posting, analytics..."</div>
										<div class="post-meta tui-muted">single · 📎 1 image</div>
									</div>
									<div class="post-item">
										<div class="post-header">
											<span class="post-campaign">dual-render / Twitter EN</span>
											<span class="post-date color-muted">draft</span>
										</div>
										<div class="post-snippet">"Half your website visitors leave if the page takes..."</div>
										<div class="post-meta tui-muted">thread · 6 tweets · 📎 1 image</div>
									</div>
								</div>
							</div>
							
							<!-- Tab 2: Schedule -->
							<div class="tui-tab-content" id="tui-tab-2">
								<div class="tui-sub-header">VERÖFFENTLICHUNGS-ZEITPLAN (NEXT UP)</div>
								<div class="schedule-timeline">
									<div class="timeline-event">
										<div class="time-badge">Mon 09:00</div>
										<div class="event-details">
											<strong>orbiter-v0365 [Twitter EN]</strong>
											<p class="tui-muted">"Your CMS is a single file..." (thread · 5 tweets)</p>
										</div>
									</div>
									<div class="timeline-event">
										<div class="time-badge">Mon 14:00</div>
										<div class="event-details">
											<strong>orbiter-v0365 [Threads EN]</strong>
											<p class="tui-muted">"Your CMS is a single file..." (single · 📎 1 image)</p>
										</div>
									</div>
									<div class="timeline-event">
										<div class="time-badge">Tue 09:00</div>
										<div class="event-details">
											<strong>dual-render [LinkedIn DE]</strong>
											<p class="tui-muted">"Die Hälfte eurer Webseiten-Besucher geht..." (single)</p>
										</div>
									</div>
								</div>
							</div>
							
							<!-- Tab 3: Settings -->
							<div class="tui-tab-content" id="tui-tab-3">
								<div class="tui-sub-header">EINSTELLUNGEN / CONFIGURATION</div>
								<div class="settings-list">
									<div class="setting-row cursor-pointing">
										<span class="setting-label">AI Provider:</span>
										<span class="setting-value color-accent">openai</span>
									</div>
									<div class="setting-row">
										<span class="setting-label">AI Model:</span>
										<span class="setting-value color-accent">gpt-4o-mini</span>
									</div>
									<div class="setting-row">
										<span class="setting-label">Dry Run:</span>
										<span class="setting-value color-failed">false</span>
									</div>
									<div class="setting-row">
										<span class="setting-label">Lizenztyp:</span>
										<span class="setting-value color-posted">Pro (Aktiv ✅)</span>
									</div>
								</div>
								<div class="tui-footer-tip" style="margin-top: 1.5rem;">
									<span class="tui-muted">Tipp: Aktiviere deine Pro-Lizenz direkt über das Terminal via:</span><br/>
									<code>postctl config set license_key PCTL-PRO-XXXX...</code>
								</div>
							</div>
						</div>
						
						<!-- Help Bar -->
						<div class="tui-help-bar">
							<span>Klicke die Tabs oben zum Navigieren</span>
							<span class="align-right">q Beenden</span>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Pricing Section (Polar.sh integration) -->
		<section id="pricing" class="pricing-section">
			<div class="container">
				<div class="section-header">
					<h2 class="section-title">Finde das passende Lizenzmodell</h2>
					<p class="section-subtitle">postctl ist Open Source. Unterstütze die Entwicklung oder schalte Premium-Features frei.</p>
				</div>

				<div class="pricing-grid">
					<!-- Core Plan -->
					<div class="pricing-card">
						<div class="plan-header">
							<h3 class="plan-name">Core (OSS)</h3>
							<div class="plan-price">0€<span class="price-period">/ dauerhaft</span></div>
							<p class="plan-desc">Perfekt für Entwickler, die ihre Posts direkt versionieren und posten möchten.</p>
						</div>
						<ul class="plan-features">
							<li><span class="check-icon">✓</span> Unbegrenzt importieren & posten</li>
							<li><span class="check-icon">✓</span> Multi-Plattform (Twitter, LinkedIn, Threads)</li>
							<li><span class="check-icon">✓</span> Vollständige Terminal UI & CLI</li>
							<li><span class="check-icon">✓</span> Lokaler Scheduler-Daemon</li>
							<li><span class="check-icon">✓</span> 100% Open Source (MIT Lizenz)</li>
						</ul>
						<div class="plan-cta">
							<a href="https://github.com/aeon022/postctl" target="_blank" rel="noopener noreferrer" class="btn btn-secondary btn-full">Auf GitHub ansehen</a>
						</div>
					</div>

					<!-- Pro Plan (Polar.sh Subscriptions) -->
					<div class="pricing-card featured">
						<div class="pricing-badge">Empfohlen</div>
						<div class="plan-header">
							<h3 class="plan-name">Pro (Polar.sh)</h3>
							<div class="plan-price">9€<span class="price-period">/ Monat</span></div>
							<p class="plan-desc">Schalte Profi-Analysen frei und unterstütze direkt die kontinuierliche Entwicklung.</p>
						</div>
						<ul class="plan-features">
							<li><span class="check-icon">✓</span> <strong>Analytics Dashboard</strong>: Auswertungen direkt im Terminal</li>
							<li><span class="check-icon">✓</span> <strong>Unbegrenzte Historie</strong> statt 3 Tage</li>
							<li><span class="check-icon">✓</span> <strong>Interaktive ASCII-Barcharts</strong> für Engagement Shares</li>
							<li><span class="check-icon">✓</span> <strong>Pro-Support</strong> bei GitHub-Issues</li>
							<li><span class="check-icon">✓</span> Generierung von Lizenzschlüsseln via Polar.sh</li>
						</ul>
						<div class="plan-cta">
							<a href="https://polar.sh/aeon022/subscriptions" target="_blank" rel="noopener noreferrer" class="btn btn-primary btn-full">Pro abonnieren via Polar.sh</a>
						</div>
					</div>
				</div>

				<!-- Donate Card -->
				<div class="donate-banner">
					<div class="donate-content">
						<h3>Möchtest du uns einfach so unterstützen?</h3>
						<p>Wir lieben Open Source. Du kannst ein einmaliges Trinkgeld spenden oder Sponsor werden.</p>
					</div>
					<div class="donate-actions">
						<a href="https://polar.sh/aeon022/donate" target="_blank" rel="noopener noreferrer" class="btn btn-primary">
							<span class="heart-icon">♥</span> Spenden auf Polar.sh
						</a>
					</div>
				</div>
			</div>
		</section>
	</main>

	<!-- Footer -->
	<footer class="footer">
		<div class="container footer-container">
			<div class="footer-left">
				<span class="logo-icon">&gt;_</span> postctl Social Manager
			</div>
			<div class="footer-right">
				<span>Lizenziert unter MIT &copy; 2026 aeon022.</span>
				<a href="https://polar.sh/aeon022" target="_blank" rel="noopener noreferrer" class="footer-link">Polar.sh Profil</a>
				<a href="https://github.com/aeon022/postctl" target="_blank" rel="noopener noreferrer" class="footer-link">GitHub</a>
			</div>
		</div>
	</footer>
</Layout>

<style>
	/* Header Navigation */
	.header {
		position: sticky;
		top: 0;
		z-index: 100;
		background: rgba(8, 9, 11, 0.8);
		backdrop-filter: blur(12px);
		border-bottom: 1px solid var(--border);
	}
	.header-container {
		display: flex;
		justify-content: space-between;
		align-items: center;
		height: 70px;
	}
	.logo {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		font-family: var(--font-heading);
		font-size: 1.5rem;
		font-weight: 700;
	}
	.logo-icon {
		color: var(--accent);
		font-family: var(--font-mono);
	}
	.nav {
		display: flex;
		align-items: center;
		gap: 2rem;
	}
	.nav-link {
		color: var(--text-secondary);
		font-weight: 500;
		font-size: 0.95rem;
	}
	.nav-link:hover {
		color: var(--text-primary);
	}
	.github-link {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.5rem 1rem;
		border-radius: 8px;
		background: var(--bg-tertiary);
		border: 1px solid var(--border);
		color: var(--text-primary);
	}
	.github-link:hover {
		border-color: var(--accent);
		background: rgba(139, 124, 248, 0.1);
	}

	/* Hero Section */
	.hero-section {
		padding: 7rem 0 4rem 0;
		position: relative;
	}
	.hero-container {
		display: grid;
		grid-template-columns: 1.2fr 1fr;
		gap: 4rem;
		align-items: center;
	}
	@media (max-width: 968px) {
		.hero-container {
			grid-template-columns: 1fr;
			gap: 3rem;
		}
	}
	.hero-content {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
	}
	.badge {
		background: var(--accent-glow);
		color: var(--accent);
		border: 1px solid rgba(139, 124, 248, 0.3);
		padding: 0.35rem 0.85rem;
		border-radius: 100px;
		font-size: 0.8rem;
		font-weight: 600;
		letter-spacing: 0.05em;
		margin-bottom: 1.5rem;
		text-transform: uppercase;
	}
	.hero-title {
		font-size: 3.5rem;
		line-height: 1.15;
		margin-bottom: 1.5rem;
	}
	@media (max-width: 640px) {
		.hero-title {
			font-size: 2.5rem;
		}
	}
	.hero-subtitle {
		font-size: 1.2rem;
		color: var(--text-secondary);
		margin-bottom: 2.5rem;
		max-width: 550px;
	}
	.hero-ctas {
		display: flex;
		flex-wrap: wrap;
		gap: 1rem;
		width: 100%;
	}
	
	/* Button Styles */
	.btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.5rem;
		padding: 0.75rem 1.5rem;
		border-radius: 8px;
		font-weight: 600;
		font-size: 0.95rem;
		cursor: pointer;
		border: 1px solid transparent;
		transition: var(--transition);
	}
	.btn-primary {
		background: var(--accent);
		color: var(--bg-primary);
	}
	.btn-primary:hover {
		background: var(--accent-hover);
		transform: translateY(-2px);
		box-shadow: 0 4px 20px var(--accent-glow);
	}
	.btn-secondary {
		background: var(--bg-secondary);
		border-color: var(--border);
		color: var(--text-primary);
	}
	.btn-secondary:hover {
		border-color: var(--accent);
		background: var(--bg-tertiary);
		transform: translateY(-2px);
	}
	.btn-tertiary {
		background: transparent;
		border-color: rgba(239, 68, 68, 0.4);
		color: #f87171;
	}
	.btn-tertiary:hover {
		background: rgba(239, 68, 68, 0.1);
		border-color: #ef4444;
		transform: translateY(-2px);
	}
	.btn-full {
		width: 100%;
	}
	.heart-icon {
		color: var(--error);
	}

	/* Interactive Terminal Emulator */
	.hero-terminal {
		background: #0d0e12;
		border: 1px solid var(--border);
		border-radius: 12px;
		box-shadow: var(--shadow-lg);
		overflow: hidden;
		min-height: 380px;
		display: flex;
		flex-direction: column;
	}
	.terminal-header {
		background: #161920;
		padding: 0.85rem 1.25rem;
		display: flex;
		align-items: center;
		justify-content: space-between;
		border-bottom: 1px solid var(--border);
	}
	.terminal-dots {
		display: flex;
		gap: 0.5rem;
	}
	.dot {
		width: 12px;
		height: 12px;
		border-radius: 50%;
		display: inline-block;
	}
	.dot-red { background: var(--error); }
	.dot-yellow { background: #f59e0b; }
	.dot-green { background: var(--success); }
	.terminal-title {
		font-family: var(--font-mono);
		font-size: 0.8rem;
		color: var(--text-secondary);
	}
	.terminal-body {
		padding: 1.5rem;
		font-family: var(--font-mono);
		font-size: 0.9rem;
		color: #e5e7eb;
		flex-grow: 1;
		line-height: 1.5;
		overflow-y: auto;
	}
	.cursor-blink {
		color: var(--accent);
		animation: blink 1s step-end infinite;
	}
	.terminal-output {
		margin-top: 1rem;
		color: #a3a3a3;
		white-space: pre-wrap;
	}
	.terminal-output.hide {
		display: none;
