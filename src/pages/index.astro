	/* Scroll Reveal Animations */
	.reveal {
		opacity: 0;
		transform: translateY(30px);
		transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1), transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
	}
	.reveal.active {
		opacity: 1;
		transform: translateY(0);
	}
</style>

<script>
	// Terminal typing simulation
	const commands = [
		{ text: "postctl import ./posts", output: "Importing posts from ./posts...\n✔ post-1.md -> Loaded successfully (5 tweets, 2 images)\n✔ post-2.md -> Loaded successfully (Single post)\n✔ post-3.md -> Loaded successfully (Single post)\n\nImport complete. 3 draft posts saved to SQLite store." },
		{ text: "postctl campaign post launch-v1 --dry-run", output: "[DRY RUN] Validating campaign 'launch-v1'...\n✔ Character validation passed (all segments < 280 chars)\n✔ Local image paths exist\n\n[DRY RUN] Posting 'launch-v1-twitter' to Twitter... Success (ID: MockTweetId)\n[DRY RUN] Posting 'launch-v1-linkedin' to LinkedIn... Success (ID: MockLinkedInId)\n\nSimulated run complete. No write actions performed." }
	];

	let commandIndex = 0;
	let charIndex = 0;
	const typingSpeed = 60;
	const delayBetweenCommands = 5000;

	const typedTextEl = document.querySelector("#typing-terminal .typed-text");
	const outputEl = document.querySelector("#typing-terminal .terminal-output");

	function typeCommand() {
		if (!typedTextEl || !outputEl) return;
		const currentCommand = commands[commandIndex];

		if (charIndex < currentCommand.text.length) {
			typedTextEl.textContent += currentCommand.text.charAt(charIndex);
			charIndex++;
			setTimeout(typeCommand, typingSpeed);
		} else {
			// Done typing, show output
			outputEl.textContent = currentCommand.output;
			outputEl.classList.remove("hide");

			// Prepare next command
			setTimeout(() => {
				charIndex = 0;
				commandIndex = (commandIndex + 1) % commands.length;
				typedTextEl.textContent = "";
				outputEl.classList.add("hide");
				outputEl.textContent = "";
				setTimeout(typeCommand, 1000);
			}, delayBetweenCommands);
		}
	}

	// Interactive TUI simulator tabs
	const tabs = document.querySelectorAll(".tui-tab");
	const tabContents = document.querySelectorAll(".tui-tab-content");

	tabs.forEach(tab => {
		tab.addEventListener("click", () => {
			const targetIndex = tab.getAttribute("data-tab");

			// Remove active class from all tabs
			tabs.forEach(t => t.classList.remove("active"));
			// Hide all contents
			tabContents.forEach(c => c.classList.remove("active"));

			// Activate current tab & content
			tab.classList.add("active");
			const targetContent = document.getElementById(`tui-tab-${targetIndex}`);
			if (targetContent) {
				targetContent.classList.add("active");
			}
		});
	});

	// Back to Top button scroll check
	const backToTopBtn = document.getElementById("back-to-top");
	window.addEventListener("scroll", () => {
		if (window.scrollY > 300) {
			backToTopBtn?.classList.add("visible");
		} else {
			backToTopBtn?.classList.remove("visible");
		}
	});

	backToTopBtn?.addEventListener("click", () => {
		const start = window.scrollY || document.documentElement.scrollTop;
		const duration = 500; // ms
		let startTime = null;

		function animation(currentTime) {
			if (startTime === null) startTime = currentTime;
			const timeElapsed = currentTime - startTime;
			const run = easeInOutQuad(timeElapsed, start, -start, duration);
			window.scrollTo(0, run);
			if (timeElapsed < duration) {
				requestAnimationFrame(animation);
			} else {
				window.scrollTo(0, 0); // ensure it lands exactly at 0
			}
		}

		function easeInOutQuad(t, b, c, d) {
			t /= d / 2;
			if (t < 1) return c / 2 * t * t + b;
			t--;
			return -c / 2 * (t * (t - 2) - 1) + b;
		}

		requestAnimationFrame(animation);
	});

	// Smooth scroll for anchor links with header offset
	document.querySelectorAll('a[href^="#"]').forEach(anchor => {
		anchor.addEventListener('click', function (e) {
			e.preventDefault();
			const targetId = this.getAttribute('href');
			if (targetId === '#') return;
			const targetElement = document.querySelector(targetId);
			if (targetElement) {
				const headerOffset = 90; // offset for the floating header
				const elementPosition = targetElement.getBoundingClientRect().top;
				const offsetPosition = elementPosition + window.pageYOffset - headerOffset;
				
				window.scrollTo({
					top: offsetPosition,
					behavior: 'smooth'
				});
			}
		});
	});

	// Intersection Observer for scroll reveal animations
	const revealElements = document.querySelectorAll(".feature-card, .how-step-card, .ai-workflow-card, .pricing-card, .section-header, .tui-emulator, .donate-banner");
	
	const revealObserver = new IntersectionObserver((entries, observer) => {
		entries.forEach(entry => {
			if (entry.isIntersecting) {
				entry.target.classList.add("active");
				observer.unobserve(entry.target);
			}
		});
	}, {
		threshold: 0.1,
		rootMargin: "0px 0px -50px 0px"
	});

	revealElements.forEach(el => {
		el.classList.add("reveal");
		revealObserver.observe(el);
	});

	// Start typing simulator on load
	window.addEventListener("DOMContentLoaded", () => {
		setTimeout(typeCommand, 1000);
	});
</script>
