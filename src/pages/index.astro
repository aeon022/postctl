---
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<!-- Decorative Grid & Glow Background -->
	<div class="bg-glow bg-glow-1"></div>
	<div class="bg-glow bg-glow-2"></div>
	<div class="grid-overlay"></div>

	<!-- Navigation Header -->
	<header class="header">
		<div class="container header-container">
			<div class="logo">
				<span class="logo-icon">&gt;_</span>
				<span class="logo-text">postctl</span>
			</div>
			<nav class="nav">
				<a href="#features" class="nav-link">Features</a>
				<a href="#how-it-works" class="nav-link">How it Works</a>
				<a href="#tui-demo" class="nav-link">TUI Demo</a>
				<a href="#ai-operator" class="nav-link">AI-Ready</a>
				<a href="#pricing" class="nav-link">Pricing</a>
				<a href="https://github.com/aeon022/postctl" target="_blank" rel="noopener noreferrer" class="nav-link github-link">
					<svg height="18" viewBox="0 0 16 16" width="18" class="github-icon"><path fill="currentColor" d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"></path></svg>
					GitHub
				</a>
			</nav>
		</div>
	</header>

	<main>
		<!-- Hero Section -->
		<section class="hero-section">
			<div class="container hero-container">
				<div class="hero-content">
					<div class="badge">Astro v6 Powered</div>
					<h1 class="hero-title">Social Media Management from your <span class="text-gradient">Terminal</span></h1>
					<p class="hero-subtitle">
						A Markdown-first, terminal-native post scheduler and publisher. Manage Twitter, LinkedIn, and Threads directly from the CLI or TUI. Zero dependencies, CGO-free, and AI-ready.
					</p>
					<div class="hero-ctas">
						<a href="#tui-demo" class="btn btn-primary">Try Interactive TUI</a>
						<a href="#pricing" class="btn btn-secondary">Get Pro License</a>
						<a href="https://polar.sh/aeon022/donate" target="_blank" rel="noopener noreferrer" class="btn btn-tertiary">
							<span class="heart-icon">♥</span> Fund on Polar.sh
						</a>
					</div>
				</div>
				
				<!-- Interactive Terminal Emulator -->
				<div class="hero-terminal">
					<div class="terminal-header">
						<div class="terminal-dots">
							<span class="dot dot-red"></span>
							<span class="dot dot-yellow"></span>
							<span class="dot dot-green"></span>
						</div>
						<div class="terminal-title">bash - postctl --help</div>
					</div>
					<div class="terminal-body" id="typing-terminal">
						<span class="terminal-prompt">$</span> <span class="typed-text"></span><span class="cursor-blink">|</span>
						<pre class="terminal-output hide"></pre>
					</div>
				</div>
			</div>
		</section>

		<!-- Features Grid Section -->
		<section id="features" class="features-section">
			<div class="container">
				<div class="section-header">
					<h2 class="section-title">Built for Developer Workflows</h2>
					<p class="section-subtitle">Why switch to bloated web UIs when you can distribute your content alongside your code?</p>
				</div>

				<div class="features-grid">
					<!-- Feature 1 -->
					<div class="feature-card">
						<div class="feature-icon">📝</div>
						<h3 class="feature-title">Markdown-First</h3>
						<p class="feature-desc">Write your posts inside your favorite editor. Frontmatter fields handle platform targets, scheduling, and image paths. Perfectly Git-versionable and reviewable in PRs.</p>
					</div>
					<!-- Feature 2 -->
					<div class="feature-card">
						<div class="feature-icon">🖥️</div>
						<h3 class="feature-title">TUI & CLI Modes</h3>
						<p class="feature-desc">Use CLI commands for instant scriptability or open the full Bubbletea-based TUI to view, edit, filter, and schedule posts interactively without context-switching.</p>
					</div>
					<!-- Feature 3 -->
					<div class="feature-card">
						<div class="feature-icon">🤖</div>
						<h3 class="feature-title">AI-as-Operator</h3>
						<p class="feature-desc">Engineered for AI assistants. Claude/GPT can generate Markdown draft files, test publication flows with `--dry-run`, and receive machine-readable outcomes using `--format json`.</p>
					</div>
					<!-- Feature 4 -->
					<div class="feature-card">
						<div class="feature-icon">⚡</div>
						<h3 class="feature-title">Zero Infrastructure</h3>
						<p class="feature-desc">Built in Go with a CGO-free SQLite storage engine. Packaged as a single offline-first binary. Copy the database file to backup all your posts and schedules.</p>
					</div>
				</div>
			</div>
		</section>

		<!-- How it Works Section (NEW) -->
		<section id="how-it-works" class="how-section">
			<div class="container">
				<div class="section-header">
					<h2 class="section-title">How It Works</h2>
					<p class="section-subtitle">Three steps from draft file to multi-platform publication.</p>
				</div>

				<div class="how-grid">
					<!-- Step 1 -->
					<div class="how-step-card">
						<div class="step-num">01</div>
						<div class="step-text-col">
							<h3 class="step-title">Write Markdown Posts</h3>
							<p class="step-desc">Structure your post as Markdown. Frontmatter defines platforms, campaigns, schedule times, and tags. Separate thread elements using headers.</p>
						</div>
						<div class="step-visual">
							<pre class="code-block"><code>---
platform: twitter
type: thread
campaign: launch-v1
schedule: 2026-06-25T09:00
images:
  - img/dashboard.png
---

## Tweet 1
Your CMS is a single file...

## Tweet 2
Calendar grid screenshots attached...
</code></pre>
						</div>
					</div>

					<!-- Step 2 -->
					<div class="how-step-card reverse">
						<div class="step-num">02</div>
						<div class="step-text-col">
							<h3 class="step-title">Import & Preview</h3>
							<p class="step-desc">Import the Markdown directory to populate the local SQLite database. Open the TUI to visually inspect thread limits, character lengths, and schedules.</p>
						</div>
						<div class="step-visual">
							<pre class="code-block"><code>$ postctl import ./posts/
Importing...
✔ post-1.md -> Import successful
✔ post-2.md -> Import successful

$ postctl list
ID                  Platform  Type    Status
launch-v1-twitter   twitter   thread  draft
launch-v1-linkedin  linkedin  single  draft
</code></pre>
						</div>
					</div>

					<!-- Step 3 -->
					<div class="how-step-card">
						<div class="step-num">03</div>
						<div class="step-text-col">
							<h3 class="step-title">Post or Run Daemon</h3>
							<p class="step-desc">Publish campaigns instantly with `--dry-run` safety gates, or start `postctl daemon` in the background to automatically trigger scheduled items.</p>
						</div>
						<div class="step-visual">
							<pre class="code-block"><code># Start background scheduler
$ postctl daemon --interval 30 --background

# Or post immediately (simulate first)
$ postctl campaign post launch-v1 --dry-run
$ postctl campaign post launch-v1
Campaign successfully posted!
</code></pre>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- TUI Interactive Simulator Section -->
		<section id="tui-demo" class="tui-section">
			<div class="container">
				<div class="section-header">
					<h2 class="section-title">Explore the Terminal UI</h2>
					<p class="section-subtitle">Click the tabs on the interactive terminal mockup below to preview the actual app dashboards.</p>
				</div>

				<!-- TUI Mockup Container -->
				<div class="tui-emulator">
					<div class="tui-emulator-header">
						<span class="tui-emulator-title">postctl — Terminal User Interface</span>
					</div>
					
					<!-- Interactive TUI Application -->
					<div class="tui-app">
						<!-- Title Bar -->
						<div class="tui-title-bar">postctl — Social Media CLI</div>
						
						<!-- Tabs Navigation -->
						<div class="tui-tabs">
							<button class="tui-tab active" data-tab="0">● Dashboard</button>
							<button class="tui-tab" data-tab="1">◷ Posts</button>
							<button class="tui-tab" data-tab="2">↺ Schedule</button>
							<button class="tui-tab" data-tab="3">⚙ Settings</button>
						</div>
						
						<!-- TUI Tab Contents -->
						<div class="tui-content-area">
							<!-- Tab 0: Dashboard -->
							<div class="tui-tab-content active" id="tui-tab-0">
								<div class="dashboard-grid">
									<div class="dashboard-col">
										<div class="tui-sub-header">CAMPAIGNS</div>
										<ul class="tui-list">
											<li><span class="color-accent">●</span> orbiter-v0365 <span class="tui-muted">(5 posts, 2 posted)</span></li>
											<li><span class="color-accent">●</span> dual-render <span class="tui-muted">(9 posts, 0 posted)</span></li>
										</ul>
										
										<div class="tui-sub-header" style="margin-top: 1.5rem;">NEXT UP</div>
										<ul class="tui-list">
											<li><span class="color-posted">◷</span> Mon 09:00 - Twitter EN</li>
											<li><span class="color-posted">◷</span> Mon 14:00 - Threads EN</li>
											<li><span class="color-posted">◷</span> Tue 09:00 - LinkedIn DE</li>
										</ul>
									</div>
									<div class="dashboard-col border-left">
										<div class="tui-sub-header">STATS</div>
										<table class="stats-table">
											<tr><td>Posted:</td><td class="color-posted align-right">12</td></tr>
											<tr><td>Scheduled:</td><td class="color-accent align-right">8</td></tr>
											<tr><td>Drafts:</td><td class="color-muted align-right">5</td></tr>
											<tr><td>Failed:</td><td class="color-failed align-right">0</td></tr>
										</table>
										
										<div class="tui-sub-header" style="margin-top: 1.5rem;">PLATFORMS</div>
										<ul class="tui-list platform-status">
											<li><span class="status-indicator active">✓</span> Twitter/X <span class="tui-muted">(connected)</span></li>
											<li><span class="status-indicator active">✓</span> LinkedIn <span class="tui-muted">(connected)</span></li>
											<li><span class="status-indicator inactive">○</span> Threads <span class="tui-muted">(not auth'd)</span></li>
										</ul>
									</div>
								</div>
							</div>
							
							<!-- Tab 1: Posts -->
							<div class="tui-tab-content" id="tui-tab-1">
								<div class="tui-sub-header">IMPORTED POSTS (FILTER: ALL)</div>
								<div class="posts-list">
									<div class="post-item selected">
										<div class="post-header">
											<span class="post-campaign">orbiter-v0365 / Twitter EN</span>
											<span class="post-date color-accent">◷ Mon 09:00</span>
										</div>
										<div class="post-snippet">"Your CMS is a single file. No database server. No Docker..."</div>
										<div class="post-meta tui-muted">thread · 5 tweets · 📎 2 images</div>
									</div>
									<div class="post-item">
										<div class="post-header">
											<span class="post-campaign">orbiter-v0365 / LinkedIn EN</span>
											<span class="post-date color-accent">◷ Wed 09:00</span>
										</div>
										<div class="post-snippet">"Shipped: Calendar view, cross-pod posting, analytics..."</div>
										<div class="post-meta tui-muted">single · 📎 1 image</div>
									</div>
									<div class="post-item">
										<div class="post-header">
											<span class="post-campaign">dual-render / Twitter EN</span>
											<span class="post-date color-muted">draft</span>
										</div>
										<div class="post-snippet">"Half your website visitors leave if the page takes..."</div>
										<div class="post-meta tui-muted">thread · 6 tweets · 📎 1 image</div>
									</div>
								</div>
							</div>
							
							<!-- Tab 2: Schedule -->
							<div class="tui-tab-content" id="tui-tab-2">
								<div class="tui-sub-header">PUBLICATION TIMELINE (NEXT UP)</div>
								<div class="schedule-timeline">
									<div class="timeline-event">
										<div class="time-badge">Mon 09:00</div>
										<div class="event-details">
											<strong>orbiter-v0365 [Twitter EN]</strong>
											<p class="tui-muted">"Your CMS is a single file..." (thread · 5 tweets)</p>
										</div>
									</div>
									<div class="timeline-event">
										<div class="time-badge">Mon 14:00</div>
										<div class="event-details">
											<strong>orbiter-v0365 [Threads EN]</strong>
											<p class="tui-muted">"Your CMS is a single file..." (single · 📎 1 image)</p>
										</div>
									</div>
									<div class="timeline-event">
										<div class="time-badge">Tue 09:00</div>
										<div class="event-details">
											<strong>dual-render [LinkedIn DE]</strong>
											<p class="tui-muted">"Die Hälfte eurer Webseiten-Besucher geht..." (single)</p>
										</div>
									</div>
								</div>
							</div>
							
							<!-- Tab 3: Settings -->
							<div class="tui-tab-content" id="tui-tab-3">
								<div class="tui-sub-header">SYSTEM CONFIGURATION</div>
								<div class="settings-list">
									<div class="setting-row cursor-pointing">
										<span class="setting-label">AI Provider:</span>
										<span class="setting-value color-accent">openai</span>
									</div>
									<div class="setting-row">
										<span class="setting-label">AI Model:</span>
										<span class="setting-value color-accent">gpt-4o-mini</span>
									</div>
									<div class="setting-row">
										<span class="setting-label">Dry Run:</span>
										<span class="setting-value color-failed">false</span>
									</div>
									<div class="setting-row">
										<span class="setting-label">License Type:</span>
										<span class="setting-value color-posted">Pro (Active ✅)</span>
									</div>
								</div>
								<div class="tui-footer-tip" style="margin-top: 1.5rem;">
									<span class="tui-muted">Tip: Activate your Pro key via command line anytime:</span><br/>
									<code>postctl config set license_key PCTL-PRO-XXXX...</code>
								</div>
							</div>
						</div>
						
						<!-- Help Bar -->
						<div class="tui-help-bar">
							<span>Click tabs above to navigate</span>
							<span class="align-right">q Quit</span>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- AI Operator workflow section (NEW) -->
		<section id="ai-operator" class="ai-operator-section">
			<div class="container">
				<div class="section-header">
					<h2 class="section-title">Designed for AI Operators</h2>
					<p class="section-subtitle">Let your AI assistant handle social media distribution while you retain total approval control.</p>
				</div>

				<div class="ai-workflow-grid">
					<div class="ai-workflow-card">
						<div class="workflow-step">
							<span class="w-icon">🤖</span>
							<h4>1. AI Generates Drafts</h4>
							<p>Your coding agent reads web contents or release files and generates formatted Markdown draft files into a directory.</p>
						</div>
					</div>
					<div class="ai-workflow-card">
						<div class="workflow-step">
							<span class="w-icon">💾</span>
							<h4>2. AI Imports & Checks</h4>
							<p>AI runs `postctl import` and checks results using `postctl list --format json`. Validation catches lengths and files.</p>
						</div>
					</div>
					<div class="ai-workflow-card">
						<div class="workflow-step">
							<span class="w-icon">🛡️</span>
							<h4>3. Dry-Run Validation</h4>
							<p>AI executes `postctl campaign post launch-v1 --dry-run` to query APIs and verify integrity without causing live posts.</p>
						</div>
					</div>
					<div class="ai-workflow-card">
						<div class="workflow-step">
							<span class="w-icon">👤</span>
							<h4>4. Human Approves & Posts</h4>
							<p>You review the simulated outcome in chat. Give the agent approval, and it triggers the final publish command.</p>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Pricing Section (Polar.sh integration) -->
		<section id="pricing" class="pricing-section">
			<div class="container">
				<div class="section-header">
					<h2 class="section-title">Transparent Gating Structure</h2>
					<p class="section-subtitle">postctl is open-source. Help fund development or upgrade to support advanced analytics.</p>
				</div>

				<div class="pricing-grid">
					<!-- Core Plan -->
					<div class="pricing-card">
						<div class="plan-header">
							<h3 class="plan-name">Core (OSS)</h3>
							<div class="plan-price">$0<span class="price-period">/ forever</span></div>
							<p class="plan-desc">For developers looking to version and post files directly from the CLI or TUI.</p>
						</div>
						<ul class="plan-features">
							<li><span class="check-icon">✓</span> Unlimited drafts & publication</li>
							<li><span class="check-icon">✓</span> Multi-platform (Twitter, LinkedIn, Threads)</li>
							<li><span class="check-icon">✓</span> Full Bubbletea TUI & Cobra CLI</li>
							<li><span class="check-icon">✓</span> In-process daemon background scheduler</li>
							<li><span class="check-icon">✓</span> 100% Open Source (MIT Licensed)</li>
						</ul>
						<div class="plan-cta">
							<a href="https://github.com/aeon022/postctl" target="_blank" rel="noopener noreferrer" class="btn btn-secondary btn-full">View Repository on GitHub</a>
						</div>
					</div>

					<!-- Pro Plan (Polar.sh Subscriptions) -->
					<div class="pricing-card featured">
						<div class="pricing-badge">Recommended</div>
						<div class="plan-header">
							<h3 class="plan-name">Pro (Polar.sh)</h3>
							<div class="plan-price">$9<span class="price-period">/ month</span></div>
							<p class="plan-desc">Unlock stats dashboard, support development, and generate secure license keys.</p>
						</div>
						<ul class="plan-features">
							<li><span class="check-icon">✓</span> <strong>Analytics Dashboard</strong>: Live engagement tracking</li>
							<li><span class="check-icon">✓</span> <strong>Unlimited analytics history</strong> (Core limits to 3 days)</li>
							<li><span class="check-icon">✓</span> <strong>Interactive ASCII Barcharts</strong> directly in terminal</li>
							<li><span class="check-icon">✓</span> <strong>Priority GitHub Support</strong> SLA</li>
							<li><span class="check-icon">✓</span> Automatic key generation and verification via Polar.sh</li>
						</ul>
						<div class="plan-cta">
							<a href="https://polar.sh/aeon022/subscriptions" target="_blank" rel="noopener noreferrer" class="btn btn-primary btn-full">Subscribe Pro via Polar.sh</a>
						</div>
					</div>
				</div>

				<!-- Donate Card -->
				<div class="donate-banner">
					<div class="donate-content">
						<h3>Want to support without a subscription?</h3>
						<p>Fund individual issues, buy us coffee, or become a one-time sponsor on Polar.sh.</p>
					</div>
					<div class="donate-actions">
						<a href="https://polar.sh/aeon022/donate" target="_blank" rel="noopener noreferrer" class="btn btn-primary">
							<span class="heart-icon">♥</span> Fund on Polar.sh
						</a>
					</div>
				</div>
			</div>
		</section>
	</main>

	<!-- Footer -->
	<footer class="footer">
		<div class="container footer-container">
			<div class="footer-left">
				<span class="logo-icon">&gt;_</span> postctl Social Manager
			</div>
			<div class="footer-right">
				<span>Licensed under MIT &copy; 2026 aeon022.</span>
				<a href="https://polar.sh/aeon022" target="_blank" rel="noopener noreferrer" class="footer-link">Polar Profile</a>
				<a href="https://github.com/aeon022/postctl" target="_blank" rel="noopener noreferrer" class="footer-link">GitHub</a>
			</div>
		</div>
	</footer>
</Layout>

<style>
	/* Background Glows */
	.bg-glow {
		position: absolute;
		width: 600px;
		height: 600px;
		background: radial-gradient(circle, var(--accent-glow) 0%, rgba(8,9,11,0) 70%);
		z-index: -2;
		pointer-events: none;
		border-radius: 50%;
	}
	.bg-glow-1 {
		top: -150px;
		left: calc(50% - 300px);
	}
	.bg-glow-2 {
		top: 800px;
		right: -200px;
	}
	.grid-overlay {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		background-image: 
			linear-gradient(var(--border) 1px, transparent 1px),
			linear-gradient(90deg, var(--border) 1px, transparent 1px);
		background-size: 80px 80px;
		z-index: -1;
		pointer-events: none;
		opacity: 0.35;
	}

	/* Header Navigation */
	.header {
		position: sticky;
		top: 0;
		z-index: 100;
		background: rgba(8, 9, 11, 0.85);
		backdrop-filter: blur(16px);
		border-bottom: 1px solid var(--border);
	}
	.header-container {
		display: flex;
		justify-content: space-between;
		align-items: center;
		height: 70px;
	}
	.logo {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		font-family: var(--font-heading);
		font-size: 1.5rem;
		font-weight: 700;
	}
	.logo-icon {
		color: var(--accent);
		font-family: var(--font-mono);
	}
	.nav {
		display: flex;
		align-items: center;
		gap: 2rem;
	}
	@media (max-width: 640px) {
		.nav {
			display: none;
		}
	}
	.nav-link {
		color: var(--text-secondary);
		font-weight: 500;
		font-size: 0.9rem;
	}
	.nav-link:hover {
		color: var(--text-primary);
	}
	.github-link {
		display: flex;
		align-items: center;
