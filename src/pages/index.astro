	/* Header Navigation */
	.header {
		position: sticky;
		top: 1.5rem;
		z-index: 100;
		width: 100%;
		display: flex;
		justify-content: center;
		padding: 0 1.5rem;
		pointer-events: none;
	}
	.header-capsule {
		pointer-events: auto;
		display: flex;
		justify-content: space-between;
		align-items: center;
		width: 100%;
		max-width: 1000px;
		height: 54px;
		padding: 0 1.5rem;
		background: rgba(13, 14, 18, 0.7);
		backdrop-filter: blur(20px) saturate(190%);
		border: 1px solid rgba(255, 255, 255, 0.08);
		border-radius: 100px;
		box-shadow: 
			0 12px 40px rgba(0, 0, 0, 0.5),
			0 0 0 1px rgba(139, 124, 248, 0.05),
			inset 0 1px 0 rgba(255, 255, 255, 0.05);
		transition: var(--transition);
	}
	@media (max-width: 1024px) {
		.header-capsule {
			padding: 0 1rem;
		}
		.logo {
			font-size: 1.1rem !important;
			gap: 0.35rem !important;
		}
		.system-status {
			display: none !important;
		}
	}
	.header-capsule:hover {
		border-color: rgba(139, 124, 248, 0.2);
		box-shadow: 
			0 12px 40px rgba(0, 0, 0, 0.6),
			0 0 15px rgba(139, 124, 248, 0.1),
			inset 0 1px 0 rgba(255, 255, 255, 0.05);
	}
	.logo {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		font-family: var(--font-heading);
		font-size: 1.25rem;
		font-weight: 700;
	}
	.logo-icon {
		color: var(--accent);
		font-family: var(--font-mono);
	}
	.logo-text {
		letter-spacing: -0.03em;
		background: linear-gradient(135deg, #fff 40%, var(--accent) 100%);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
	}
	.logo-blink {
		color: var(--accent);
		font-family: var(--font-mono);
		animation: cursor-blink 1s infinite;
	}
	@keyframes cursor-blink {
		0%, 100% { opacity: 0; }
		50% { opacity: 1; }
	}
	.system-status {
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		background: rgba(16, 185, 129, 0.08);
		border: 1px solid rgba(16, 185, 129, 0.2);
		color: var(--success);
		font-family: var(--font-mono);
		font-size: 0.65rem;
		padding: 0.15rem 0.4rem;
		border-radius: 100px;
		letter-spacing: 0.05em;
		font-weight: 500;
		margin-left: 0.25rem;
	}
	.status-dot {
		width: 5px;
		height: 5px;
		background-color: var(--success);
		border-radius: 50%;
		box-shadow: 0 0 8px var(--success);
		animation: pulse 2s infinite;
	}
	@keyframes pulse {
		0%, 100% { transform: scale(1); opacity: 0.8; }
		50% { transform: scale(1.3); opacity: 1; }
	}
	.nav {
		display: flex;
		align-items: center;
		gap: 1rem;
	}
	@media (max-width: 1024px) {
		.nav {
			gap: 0.4rem;
		}
		.nav-link {
			font-size: 0.78rem;
			padding: 0.3rem 0.5rem;
		}
		.github-link {
			padding: 0.3rem 0.6rem;
		}
	}
	@media (max-width: 880px) {
		.nav-link[href="#how-it-works"],
		.nav-link[href="/tui"] {
			display: none;
		}
	}
	@media (max-width: 768px) {
		.nav {
			display: none;
		}
	}
	.nav-link {
		color: var(--text-secondary);
		font-weight: 500;
		font-size: 0.85rem;
		padding: 0.35rem 0.65rem;
		border-radius: 100px;
		transition: var(--transition);
		white-space: nowrap;
		flex-shrink: 0;
	}
	.nav-link:hover {
		color: var(--text-primary);
		background: rgba(255, 255, 255, 0.04);
	}
	.github-link {
		display: flex;
		align-items: center;
		gap: 0.35rem;
		padding: 0.4rem 0.8rem;
		border-radius: 100px;
		background: rgba(139, 124, 248, 0.06);
		border: 1px solid rgba(139, 124, 248, 0.15);
		color: var(--accent);
		font-family: var(--font-mono);
		font-size: 0.8rem;
		white-space: nowrap;
		flex-shrink: 0;
	}
	.github-link:hover {
		border-color: var(--accent);
		background: rgba(139, 124, 248, 0.12);
		color: var(--accent-hover);
		box-shadow: 0 0 10px rgba(139, 124, 248, 0.15);
	}

	/* Hero Section */
	.hero-section {
		padding: 7rem 0 5rem 0;
	}
	.hero-container {
		display: grid;
		grid-template-columns: 1.1fr 1fr;
		gap: 4rem;
		align-items: center;
	}
	@media (max-width: 968px) {
		.hero-container {
			grid-template-columns: 1fr;
			gap: 3.5rem;
		}
	}
	.hero-content {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
	}
	.badge {
		background: var(--accent-glow);
		color: var(--accent);
		border: 1px solid rgba(139, 124, 248, 0.35);
		padding: 0.35rem 0.85rem;
		border-radius: 100px;
		font-size: 0.75rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		margin-bottom: 1.5rem;
		text-transform: uppercase;
	}
	.hero-title {
		font-size: 3.8rem;
		line-height: 1.1;
		margin-bottom: 1.5rem;
	}
	@media (max-width: 640px) {
		.hero-title {
			font-size: 2.8rem;
		}
	}
	.hero-subtitle {
		font-size: 1.15rem;
		color: var(--text-secondary);
		margin-bottom: 2.5rem;
		max-width: 550px;
		line-height: 1.7;
	}
	.hero-ctas {
		display: flex;
		flex-wrap: wrap;
		gap: 1rem;
		width: 100%;
	}
	
	/* Button Styles */
	.btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.5rem;
		padding: 0.75rem 1.5rem;
		border-radius: 8px;
		font-weight: 600;
		font-size: 0.9rem;
		cursor: pointer;
		border: 1px solid transparent;
		transition: var(--transition);
	}
	.btn-primary {
		background: var(--accent);
		color: var(--bg-primary);
	}
	.btn-primary:hover {
		background: var(--accent-hover);
		transform: translateY(-2px);
		box-shadow: 0 4px 20px var(--accent-glow);
	}
	.btn-secondary {
		background: var(--bg-secondary);
		border-color: var(--border);
		color: var(--text-primary);
	}
	.btn-secondary:hover {
		border-color: var(--accent);
		background: var(--bg-tertiary);
		transform: translateY(-2px);
	}
	.btn-tertiary {
		background: transparent;
		border-color: rgba(239, 68, 68, 0.4);
		color: #f87171;
	}
	.btn-tertiary:hover {
		background: rgba(239, 68, 68, 0.08);
		border-color: #ef4444;
		transform: translateY(-2px);
	}
	.btn-full {
		width: 100%;
	}
	.heart-icon {
		color: #ff4a5a;
		fill: #ff4a5a;
		display: inline-block;
		vertical-align: middle;
		margin-right: 0.35rem;
		margin-top: -2px;
	}

	/* Interactive Terminal Emulator */
	.hero-terminal {
		background: #0d0e12;
		border: 1px solid var(--border);
		border-radius: 12px;
		box-shadow: var(--shadow-lg);
		overflow: hidden;
		min-height: 400px;
		display: flex;
		flex-direction: column;
	}
	.terminal-header {
		background: #161920;
		padding: 0.85rem 1.25rem;
		display: flex;
		align-items: center;
		justify-content: space-between;
		border-bottom: 1px solid var(--border);
	}
	.terminal-dots {
		display: flex;
		gap: 0.5rem;
	}
	.dot {
		width: 12px;
		height: 12px;
		border-radius: 50%;
		display: inline-block;
	}
	.dot-red { background: var(--error); }
	.dot-yellow { background: #f59e0b; }
	.dot-green { background: var(--success); }
	.terminal-title {
		font-family: var(--font-mono);
		font-size: 0.8rem;
		color: var(--text-secondary);
	}
	.terminal-body {
		padding: 1.5rem;
		font-family: var(--font-mono);
		font-size: 0.85rem;
		color: #e5e7eb;
		flex-grow: 1;
		line-height: 1.6;
		overflow-y: auto;
	}
	.cursor-blink {
		color: var(--accent);
		animation: blink 1s step-end infinite;
	}
	.terminal-output {
		margin-top: 1rem;
		color: #a3a3a3;
		white-space: pre-wrap;
	}
	.terminal-output.hide {
		display: none;
	}
	@keyframes blink {
		from, to { color: transparent }
		50% { color: var(--accent) }
	}

	/* Section Commons */
	.section-header {
		text-align: center;
		max-width: 700px;
		margin: 0 auto 4.5rem auto;
	}
	.section-title {
		font-size: 2.6rem;
		margin-bottom: 1rem;
		letter-spacing: -0.01em;
	}
	.section-subtitle {
		color: var(--text-secondary);
		font-size: 1.1rem;
		line-height: 1.6;
	}

	/* Features Section */
	.features-section {
		padding: 6.5rem 0;
		border-top: 1px solid var(--border);
		background: rgba(17, 19, 24, 0.45);
	}
	.features-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
		gap: 2rem;
	}
	.feature-card {
		background: var(--bg-secondary);
		border: 1px solid var(--border);
		border-radius: 12px;
		padding: 2.25rem;
		transition: var(--transition);
	}
	.feature-card:hover {
		border-color: var(--accent);
		transform: translateY(-4px);
		box-shadow: 0 0 30px rgba(139, 124, 248, 0.05);
	}
	.feature-icon {
		display: inline-block;
		color: var(--accent);
		margin-bottom: 1.5rem;
	}
	.feature-title {
		font-size: 1.3rem;
		margin-bottom: 0.75rem;
	}
	.feature-desc {
		color: var(--text-secondary);
		font-size: 0.95rem;
		line-height: 1.6;
	}

	/* How It Works Section (NEW) */
	.how-section {
		padding: 6.5rem 0;
		border-top: 1px solid var(--border);
	}
	.how-grid {
		display: flex;
		flex-direction: column;
		gap: 5rem;
		max-width: 950px;
		margin: 0 auto;
	}
	.how-step-card {
		display: flex;
		align-items: center;
		gap: 4rem;
	}
	.how-step-card.reverse {
		flex-direction: row-reverse;
	}
	@media (max-width: 768px) {
		.how-step-card, .how-step-card.reverse {
			flex-direction: column;
			align-items: flex-start;
			gap: 2rem;
		}
	}
	.step-num {
		font-family: var(--font-heading);
		font-size: 4rem;
		font-weight: 800;
		color: var(--accent);
		opacity: 0.15;
		line-height: 1;
	}
	.step-text-col {
		flex: 1;
	}
	.step-title {
		font-size: 1.6rem;
		margin-bottom: 0.75rem;
	}
	.step-desc {
		color: var(--text-secondary);
		line-height: 1.6;
	}
	.step-visual {
		flex: 1.2;
		background: #0d0e12;
		border: 1px solid var(--border);
		border-radius: 8px;
		padding: 1.25rem;
		font-family: var(--font-mono);
		font-size: 0.8rem;
		color: #e5e7eb;
		width: 100%;
		max-height: 250px;
		overflow-y: auto;
	}
	.code-block {
		margin: 0;
	}

	/* TUI Emulator Section */
	.tui-section {
		padding: 6.5rem 0;
		border-top: 1px solid var(--border);
		background: rgba(17, 19, 24, 0.45);
	}
	.tui-emulator {
		max-width: 900px;
		margin: 0 auto;
		background: #08090b;
		border: 1px solid rgba(255, 255, 255, 0.12);
		border-radius: 12px;
		overflow: hidden;
		box-shadow: var(--shadow-lg);
	}
	.tui-emulator-header {
		background: #111318;
		padding: 0.65rem 1.25rem;
		border-bottom: 1px solid rgba(255, 255, 255, 0.1);
		font-family: var(--font-mono);
		font-size: 0.8rem;
		color: var(--text-secondary);
	}
	
	/* Mock TUI CSS */
	.tui-app {
		background: #1c1d22;
		font-family: var(--font-mono);
		font-size: 0.85rem;
		color: #e5e7eb;
		display: flex;
		flex-direction: column;
		height: 380px;
	}
	.tui-title-bar {
		background: var(--accent);
		color: #000;
		padding: 0.25rem 1rem;
		font-weight: bold;
		text-align: center;
	}
	.tui-tabs {
		display: flex;
		background: #272930;
		border-bottom: 1px solid rgba(255, 255, 255, 0.05);
		overflow-x: auto;
		white-space: nowrap;
		scrollbar-width: none; /* Hide scrollbar for clean UI on Firefox */
		-webkit-overflow-scrolling: touch;
	}
	.tui-tabs::-webkit-scrollbar {
		display: none; /* Hide scrollbar for Chrome/Safari */
	}
	.tui-tab {
		background: transparent;
		border: none;
		outline: none;
		color: var(--text-secondary);
		padding: 0.5rem 1rem;
		font-family: inherit;
		font-size: inherit;
		cursor: pointer;
		transition: var(--transition);
		flex-shrink: 0;
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
	}
	.tab-icon {
		color: var(--text-muted);
		transition: var(--transition);
	}
	.tui-tab:hover {
		color: var(--text-primary);
		background: rgba(255,255,255,0.03);
	}
	.tui-tab:hover .tab-icon {
		color: var(--text-primary);
	}
	.tui-tab.active {
		background: #1c1d22;
		color: var(--accent);
		font-weight: bold;
	}
	.tui-tab.active .tab-icon {
		color: var(--accent);
	}
	.tui-content-area {
		padding: 1.5rem;
		flex-grow: 1;
		overflow-y: auto;
	}
	.tui-tab-content {
		display: none;
	}
	.tui-tab-content.active {
		display: block;
	}
	.tui-sub-header {
		color: var(--accent);
		font-weight: bold;
		border-bottom: 1px solid rgba(139, 124, 248, 0.3);
		padding-bottom: 0.25rem;
		margin-bottom: 1rem;
		font-size: 0.75rem;
		letter-spacing: 0.05em;
	}
	.tui-list {
		list-style: none;
	}
	.tui-list li {
		margin-bottom: 0.5rem;
	}
	.tui-muted {
		color: var(--text-muted);
	}
	.color-accent { color: var(--accent); }
	.color-posted { color: var(--success); }
	.color-failed { color: var(--error); }
	.align-right { text-align: right; }
	
	/* Dashboard Specific Mock TUI */
	.dashboard-grid {
		display: grid;
		grid-template-columns: 1.3fr 1fr;
		gap: 2rem;
		height: 100%;
	}
	.border-left {
		border-left: 1px dashed rgba(255, 255, 255, 0.1);
		padding-left: 1.5rem;
	}
	.stats-table {
		width: 100%;
		border-collapse: collapse;
		margin-bottom: 1rem;
	}
	.stats-table td {
		padding: 0.25rem 0;
	}
	.platform-status .status-indicator {
		display: inline-block;
		width: 18px;
		font-weight: bold;
	}
	.platform-status .status-indicator.active {
		color: var(--success);
	}
	.platform-status .status-indicator.inactive {
		color: var(--text-muted);
	}

	/* Posts Mock TUI */
	.posts-list {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}
	.post-item {
		padding: 0.5rem 0.75rem;
		border-radius: 4px;
		border: 1px solid transparent;
	}
	.post-item.selected {
		background: rgba(139, 124, 248, 0.1);
		border-color: rgba(139, 124, 248, 0.4);
	}
	.post-header {
		display: flex;
		justify-content: space-between;
		margin-bottom: 0.25rem;
		font-weight: bold;
	}
	.post-snippet {
		font-size: 0.8rem;
		color: var(--text-primary);
		margin-bottom: 0.25rem;
	}
	.post-meta {
		font-size: 0.75rem;
	}

	/* Schedule Mock TUI */
	.schedule-timeline {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}
	.timeline-event {
		display: flex;
		gap: 1.5rem;
		align-items: flex-start;
	}
	.time-badge {
		background: #272930;
		padding: 0.25rem 0.5rem;
		border-radius: 4px;
		font-size: 0.75rem;
		min-width: 90px;
		text-align: center;
	}
	
	/* Settings Mock TUI */
	.settings-list {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}
	.setting-row {
		display: flex;
		gap: 1rem;
		padding: 0.25rem 0.5rem;
	}
	.setting-row.cursor-pointing {
		background: rgba(255, 255, 255, 0.03);
		border-left: 2px solid var(--accent);
	}
	.setting-label {
		color: var(--text-secondary);
		min-width: 120px;
	}

	/* Editor Mock TUI */
	.editor-mock {
		display: flex;
		flex-direction: column;
		gap: 0.35rem;
		font-size: 0.76rem;
	}
	.editor-row {
		margin-bottom: 0.1rem;
	}
	.editor-input-mock {
		color: var(--accent);
		background: #272930;
		padding: 0.1rem 0.4rem;
		border-radius: 2px;
	}
	.editor-textarea-mock {
		border: 1px solid rgba(255, 255, 255, 0.1);
		border-radius: 4px;
		background: #111318;
		padding: 0.4rem;
		font-size: 0.7rem;
		color: var(--text-primary);
		min-height: 55px;
		white-space: pre-wrap;
		line-height: 1.25;
	}
	.editor-actions {
		margin-top: 0.25rem;
		display: flex;
		gap: 0.6rem;
	}
	.btn-mock {
		font-weight: bold;
		cursor: pointer;
		font-size: 0.72rem;
	}

	/* Readme Mock TUI */
	.readme-split-mock {
		display: grid;
		grid-template-columns: 1fr 1.8fr;
		gap: 1rem;
		height: 220px;
	}
	.readme-toc-mock {
		border-right: 1px dashed rgba(255, 255, 255, 0.1);
		padding-right: 0.5rem;
	}
	.readme-body-mock {
		padding-left: 0.5rem;
		overflow-y: auto;
	}
	.readme-text-mock {
		font-size: 0.7rem;
		line-height: 1.35;
		color: var(--text-secondary);
		white-space: pre-wrap;
	}

	.tui-help-bar {
		background: #111318;
		padding: 0.25rem 1rem;
		font-size: 0.75rem;
		color: var(--text-secondary);
		display: flex;
		justify-content: space-between;
		border-top: 1px solid rgba(255, 255, 255, 0.05);
	}

	/* AI Operator workflow section (NEW) */
	.ai-operator-section {
		padding: 6.5rem 0;
		border-top: 1px solid var(--border);
	}
	.ai-workflow-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
		gap: 2rem;
		margin-top: 2rem;
	}
	.ai-workflow-card {
		background: var(--bg-secondary);
		border: 1px solid var(--border);
		border-radius: 12px;
		padding: 2.25rem;
		text-align: center;
		transition: var(--transition);
	}
	.ai-workflow-card:hover {
		border-color: rgba(255,255,255,0.12);
	}
	.w-icon {
		display: inline-block;
		color: var(--accent);
		margin-bottom: 1rem;
	}
	.workflow-step h4 {
		font-size: 1.15rem;
		margin-bottom: 0.75rem;
	}
	.workflow-step p {
		font-size: 0.9rem;
		color: var(--text-secondary);
		line-height: 1.5;
	}
	/* Roadmap Section */
	.roadmap-section {
		padding: 6.5rem 0;
		border-top: 1px solid var(--border);
		position: relative;
	}
	.roadmap-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
		gap: 2rem;
		margin-top: 3.5rem;
	}
	.roadmap-card {
		background: rgba(255, 255, 255, 0.01);
		border: 1px solid rgba(255, 255, 255, 0.06);
		border-radius: 12px;
		padding: 2rem;
		transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
		position: relative;
		overflow: hidden;
	}
	.roadmap-card::before {
		content: '';
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 2px;
		background: linear-gradient(90deg, transparent, var(--accent), transparent);
		transform: scaleX(0);
		transition: transform 0.5s ease;
	}
	.roadmap-card:hover {
		transform: translateY(-5px);
		border-color: rgba(139, 124, 248, 0.25);
		box-shadow: 
			0 12px 30px rgba(0, 0, 0, 0.4),
			0 0 15px rgba(139, 124, 248, 0.05);
		background: rgba(255, 255, 255, 0.02);
	}
	.roadmap-card:hover::before {
		transform: scaleX(1);
	}
	.roadmap-badge {
		display: inline-block;
		font-size: 0.7rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		padding: 0.25rem 0.6rem;
		border-radius: 100px;
		margin-bottom: 1.25rem;
	}
	.roadmap-badge.next {
		background: rgba(139, 124, 248, 0.15);
		color: var(--accent);
		border: 1px solid rgba(139, 124, 248, 0.3);
	}
	.roadmap-badge.future {
		background: rgba(255, 255, 255, 0.05);
		color: var(--text-secondary);
		border: 1px solid rgba(255, 255, 255, 0.1);
	}
	.roadmap-title {
		font-family: var(--font-heading);
		font-size: 1.15rem;
		font-weight: 650;
		color: #fff;
		margin-bottom: 0.75rem;
	}
	.roadmap-desc {
		font-size: 0.85rem;
		line-height: 1.6;
		color: var(--text-secondary);
	}

	/* Pricing Section */
	.pricing-section {
		padding: 6.5rem 0;
		border-top: 1px solid var(--border);
		background: rgba(17, 19, 24, 0.45);
	}
	.pricing-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
		gap: 2.5rem;
		max-width: 900px;
		margin: 0 auto;
	}
	.pricing-card {
		background: var(--bg-secondary);
		border: 1px solid var(--border);
		border-radius: 16px;
		padding: 3rem 2.5rem;
		position: relative;
		display: flex;
		flex-direction: column;
		height: 100%;
		transition: var(--transition);
	}
	.pricing-card:hover {
		border-color: rgba(255,255,255,0.15);
		transform: translateY(-4px);
	}
	.pricing-card.featured {
		border-color: var(--accent);
		background: linear-gradient(180deg, rgba(139, 124, 248, 0.05) 0%, rgba(8, 9, 11, 0) 100%), var(--bg-secondary);
		box-shadow: 0 10px 40px rgba(139, 124, 248, 0.15);
	}
	.pricing-badge {
		position: absolute;
		top: 1.25rem;
		right: 1.5rem;
		background: var(--accent);
		color: var(--bg-primary);
		font-size: 0.7rem;
		font-weight: 700;
		padding: 0.25rem 0.75rem;
		border-radius: 100px;
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}
	.plan-header {
		margin-bottom: 2rem;
	}
	.plan-name {
		font-size: 1.5rem;
		margin-bottom: 0.5rem;
	}
	.plan-price {
		font-size: 3rem;
		font-weight: 700;
		color: var(--text-primary);
		margin-bottom: 0.5rem;
		display: flex;
		align-items: baseline;
	}
	.price-original {
		font-size: 1.75rem;
		text-decoration: line-through;
		color: var(--text-muted);
		margin-right: 0.5rem;
		font-weight: 500;
	}
	.launch-special-tag {
		font-family: var(--font-mono, monospace);
		font-size: 0.72rem;
		color: var(--success);
		background: rgba(16, 185, 129, 0.08);
		border: 1px solid rgba(16, 185, 129, 0.2);
		padding: 0.25rem 0.5rem;
		border-radius: 4px;
		display: inline-block;
		margin-bottom: 1rem;
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}
	.promo-code-box {
		font-family: var(--font-mono, monospace);
		font-size: 0.75rem;
		background: rgba(139, 124, 248, 0.06);
		border: 1px solid rgba(139, 124, 248, 0.2);
		padding: 0.35rem 0.65rem;
		border-radius: 6px;
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		margin-bottom: 1rem;
	}
	.promo-label {
		color: var(--text-secondary);
		text-transform: uppercase;
		font-size: 0.68rem;
		letter-spacing: 0.05em;
	}
	.promo-value {
		color: var(--accent);
		font-weight: 600;
	}
	.price-period {
		font-size: 1rem;
		color: var(--text-secondary);
		font-weight: 400;
		margin-left: 0.25rem;
	}
	.plan-desc {
		color: var(--text-secondary);
		font-size: 0.95rem;
	}
	.plan-features {
		list-style: none;
		margin-bottom: 2.5rem;
	}
	.plan-cta {
		margin-top: auto;
	}
	.plan-features li {
		display: flex;
		align-items: flex-start;
		gap: 0.75rem;
		margin-bottom: 0.85rem;
		font-size: 0.9rem;
		color: var(--text-secondary);
		line-height: 1.5;
	}
	.check-icon {
		color: var(--success);
		font-weight: bold;
		flex-shrink: 0;
		margin-top: 0.15rem;
	}
	
	/* Donate Banner */
	.donate-banner {
		background: var(--bg-secondary);
		border: 1px solid var(--border);
		border-radius: 16px;
		padding: 2.5rem;
		display: flex;
		justify-content: space-between;
		align-items: center;
		margin-top: 4.5rem;
		flex-wrap: wrap;
		gap: 2rem;
	}
	@media (max-width: 768px) {
		.donate-banner {
			flex-direction: column;
			text-align: center;
		}
	}
	.donate-content h3 {
		font-size: 1.5rem;
		margin-bottom: 0.5rem;
	}
	.donate-content p {
		color: var(--text-secondary);
	}

	/* Footer Styling */
	.footer {
		padding: 4rem 0;
		border-top: 1px solid var(--border);
		background: var(--bg-primary);
		color: var(--text-secondary);
		font-size: 0.85rem;
	}
	.footer-container {
		display: flex;
		justify-content: space-between;
		align-items: center;
		flex-wrap: wrap;
		gap: 1.5rem;
	}
	@media (max-width: 640px) {
		.footer-container {
			flex-direction: column;
			text-align: center;
		}
	}
	.footer-left {
		font-family: var(--font-heading);
		font-weight: 700;
		font-size: 1.1rem;
		color: var(--text-primary);
		display: flex;
		align-items: center;
		gap: 0.5rem;
	}
	.footer-right {
		display: flex;
		gap: 2rem;
		flex-wrap: wrap;
		justify-content: center;
	}
	.footer-link:hover {
		color: var(--text-primary);
	}

	/* Back to Top Button */
	.back-to-top {
		position: fixed;
		bottom: 2rem;
		right: 2rem;
		z-index: 99;
		background: rgba(13, 14, 18, 0.8);
		backdrop-filter: blur(8px);
		border: 1px solid var(--border);
		color: var(--text-secondary);
		width: 44px;
		height: 44px;
		border-radius: 50%;
		display: flex;
		align-items: center;
		justify-content: center;
		cursor: pointer;
		opacity: 0;
		visibility: hidden;
		transform: translateY(10px);
		transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
		box-shadow: var(--shadow-md);
	}
	.back-to-top.visible {
		opacity: 1;
		visibility: visible;
		transform: translateY(0);
	}
	.back-to-top:hover {
		color: var(--accent);
		border-color: var(--accent);
		box-shadow: 0 0 15px var(--accent-glow);
		transform: translateY(-2px);
	}

	/* Scroll Reveal Animations */
	.reveal {
		opacity: 0;
		transform: translateY(36px);
		transition: opacity 0.75s cubic-bezier(0.16, 1, 0.3, 1), transform 0.75s cubic-bezier(0.16, 1, 0.3, 1);
	}
	.reveal.active {
		opacity: 1;
		transform: translateY(0);
	}
	.reveal-delay-1 { transition-delay: 0.1s; }
	.reveal-delay-2 { transition-delay: 0.2s; }
	.reveal-delay-3 { transition-delay: 0.3s; }

	/* Page transition */
	@keyframes page-fade-in {
		from { opacity: 0; transform: translateY(12px); }
		to   { opacity: 1; transform: translateY(0); }
	}
	main {
		animation: page-fade-in 0.55s cubic-bezier(0.16, 1, 0.3, 1) both;
	}

	/* Screenshot section improvements */

	/* ── TUI Demo ──────────────────────────────────────────── */
	.tui-demo-section {
		padding: 5rem 0 6rem;
	}
	.tui-window {
		width: 100%;
		max-width: 900px;
		margin: 0 auto;
		background: #1a202c; /* ColorBg from styles.go */
		border: 1px solid #2d3748; /* ColorDarkGray from styles.go */
		border-radius: 10px;
		overflow: hidden;
		box-shadow: 0 0 0 1px rgba(255,255,255,0.04), 0 32px 80px rgba(0,0,0,0.7), 0 0 60px rgba(139,124,248,0.06);
		outline: none;
		transition: box-shadow 0.2s ease;
	}
	.tui-window:focus {
		box-shadow: 0 0 0 2px rgba(139,124,248,0.4), 0 32px 80px rgba(0,0,0,0.7), 0 0 60px rgba(139,124,248,0.12);
	}

	/* Window top bar (Mac style dots) */
	.tui-chrome {
		background: #0d0e14;
		border-bottom: 1px solid rgba(255,255,255,0.07);
		display: grid;
		grid-template-columns: auto 1fr auto;
		align-items: center;
		padding: 0.6rem 1rem;
		gap: 1rem;
	}
	.tui-dots { display: flex; gap: 0.4rem; align-items: center; }
	.tui-dot { width: 12px; height: 12px; border-radius: 50%; }
	.tui-dot-red    { background: #ff5f57; }
	.tui-dot-yellow { background: #ffbd2e; }
	.tui-dot-green  { background: #28c840; }
	.tui-chrome-title {
		text-align: center;
		color: rgba(255,255,255,0.4);
		font-family: var(--font-mono);
		font-size: 0.78rem;
		letter-spacing: 0.04em;
	}

	/* Terminal Inner content wrapper */
	.tui-window-content {
		padding: 1.5rem;
		background: #1a202c; /* ColorBg */
	}

	/* Title Block */
	.tui-title-block {
		background: #8b7cf8; /* ColorPrimary */
		color: #1a202c; /* ColorBg */
		font-weight: bold;
		padding: 0.1rem 0.5rem;
		display: inline-block;
		margin-bottom: 1.25rem;
		font-family: var(--font-mono);
		font-size: 0.85rem;
	}

	/* Tab bar (mimics tabs.go horizontal layout) */
	.tui-tabbar {
		display: flex;
		background: #1a202c;
		border-bottom: 2px solid #8b7cf8; /* ColorPrimary line */
		padding: 0;
		gap: 2px;
		margin-bottom: 1.5rem;
	}
	.tui-tab-btn {
		background: #1a202c;
		border: 1px solid #2d3748; /* ColorDarkGray */
		border-bottom: none;
		color: #718096; /* ColorLightGray */
		font-family: var(--font-mono);
		font-size: 0.8rem;
		font-weight: bold;
		padding: 0.45rem 1rem;
		cursor: pointer;
		border-radius: 4px 4px 0 0;
		display: flex;
		align-items: center;
		gap: 0.4rem;
		position: relative;
		bottom: -2px; /* overlap with tabbar border-bottom */
		z-index: 1;
		transition: color 0.15s ease;
	}
	.tui-tab-btn:hover { color: #cbd5e0; }
	.tui-tab-btn.active {
		color: #00f5d4; /* ColorSecondary */
		border-color: #8b7cf8; /* ColorPrimary */
		border-bottom: 2px solid #1a202c; /* hide tabbar bottom line */
		z-index: 2;
	}

	/* Panel body */
	.tui-body {
		min-height: 280px;
		background: #1a202c;
		color: #ecc94b; /* Default terminal text: Yellow */
		font-family: var(--font-mono);
		font-size: 0.85rem;
	}
	.tui-panel { display: none; }
	.tui-panel.active { display: block; }

	/* Layout elements */
	.tui-dashboard-layout {
		display: grid;
		grid-template-columns: 43fr 35fr;
		gap: 1.5rem;
		align-items: start;
	}
	@media (max-width: 768px) {
		.tui-dashboard-layout {
			grid-template-columns: 1fr;
			gap: 1rem;
		}
	}

	/* Lipgloss StyleBox simulation */
	.tui-box {
		border: 1px solid #2d3748; /* ColorDarkGray */
		border-radius: 8px; /* RoundedBorder */
		padding: 1rem 1.25rem;
		background: transparent;
		box-sizing: border-box;
	}

	/* Headers inside boxes */
	.tui-label {
		color: #8b7cf8; /* ColorPrimary */
		font-weight: bold;
		font-size: 0.82rem;
		letter-spacing: 0.05em;
		margin-bottom: 0.75rem;
	}

	/* Text styles */
	.tui-muted  { color: #718096; } /* ColorLightGray */
	.tui-val    { color: #ecc94b; } /* Default is same as text, but explicitly yellow */
	.tui-ok     { color: #48bb78; } /* ColorPosted */
	.tui-warn   { color: #ecc94b; } /* ColorScheduled */
	.tui-error  { color: #f56565; } /* ColorFailed */
	.tui-connected { color: #48bb78; font-weight: bold; }
	.tui-gap    { height: 1rem; }

	/* Cursor arrows */
	.tui-arr    { color: #00f5d4; font-weight: bold; margin-right: 0.5rem; display: inline-block; }
	.tui-arr-h  { opacity: 0; }

	/* Campaigns tab styling */
	.tui-campaign-item {
		display: flex;
		align-items: center;
		padding: 0.1rem 0;
	}
	.tui-rtitle { color: #ecc94b; }
	.tui-meta   { color: #ecc94b; font-size: 0.82rem; margin-bottom: 0.4rem; }

	/* Stats rows */
	.tui-stat-r {
		display: flex;
		gap: 0.5rem;
		margin-bottom: 0.2rem;
		color: #ecc94b;
	}

	/* Platform list rows */
	.tui-plat-r {
		display: flex;
		gap: 0.5rem;
		margin-bottom: 0.2rem;
		color: #ecc94b;
	}

	/* Posts list */
	.tui-post-item {
		margin-bottom: 0.9rem;
	}
	.tui-post-header-line {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		color: #ecc94b;
	}
	.tui-post-meta-plat {
		font-weight: bold;
	}
	.tui-post-badge {
		font-size: 0.72rem;
		font-weight: bold;
		padding: 0 0.4rem;
		border-radius: 2px;
	}
	.badge-posted {
		background: #48bb78;
		color: #1a202c;
	}
	.badge-scheduled {
		background: #ecc94b;
		color: #1a202c;
	}
	.badge-draft {
		background: #a0aec0;
		color: #1a202c;
	}
	.badge-failed {
		background: #f56565;
		color: #f7fafc;
	}
	.tui-post-body {
		color: #cbd5e0;
		margin-left: 2ch;
		padding-left: 1.2rem;
		margin-top: 0.15rem;
		font-weight: bold;
	}
	.tui-post-meta-line {
		color: #718096;
		margin-left: 2ch;
		padding-left: 1.2rem;
		margin-top: 0.1rem;
		font-size: 0.78rem;
	}
	/* Selected post item */
	.tui-post-item.tui-row-sel .tui-post-body {
		color: #00f5d4 !important;
	}

	/* Schedule tab */
	.tui-sch-item {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		padding: 0.15rem 0;
	}
	.tui-sch-icon {
		color: #8b7cf8;
	}
	.tui-sch-time {
		min-width: 150px;
		color: #ecc94b;
	}
	.tui-sch-plat {
		min-width: 90px;
		font-weight: bold;
		color: #ecc94b;
	}
	.tui-sch-lang {
		min-width: 30px;
		color: #ecc94b;
	}
	.tui-sch-title {
		color: #ecc94b;
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
	}
	/* Selected schedule item */
	.tui-sch-item.tui-row-sel .tui-sch-plat {
		color: #00f5d4 !important;
	}

	/* History tab */
	.tui-hist-row {
		display: flex;
		align-items: center;
		gap: 1.2rem;
		padding: 0.2rem 0;
	}
	.tui-hist-time {
		color: #ecc94b;
		min-width: 170px;
	}
	.tui-hist-action {
		min-width: 70px;
		font-weight: bold;
	}
	.tui-hist-action.tui-ok {
		color: #48bb78;
	}
	.tui-hist-action.tui-error {
		color: #f56565;
	}
	.tui-hist-info {
		color: #718096;
	}
	/* Selected history item */
	.tui-hist-row.tui-row-sel .tui-hist-info {
		color: #00f5d4 !important;
	}

	/* Settings tab */
	.tui-set-row {
		display: flex;
		align-items: center;
		padding: 0.15rem 0;
		color: #ecc94b;
		font-family: var(--font-mono);
	}
	.tui-skey {
		white-space: pre;
	}
	.tui-sval {
		margin-left: 0.5rem;
		font-weight: bold;
	}
	.val-cyan {
		color: #00f5d4;
	}
	.val-red {
		color: #f56565;
	}
	.val-green {
		color: #48bb78;
	}
	.val-gray {
		color: #718096;
	}
	/* Selected setting row */
	.tui-set-row.tui-row-sel .tui-skey {
		color: #00f5d4 !important;
		font-weight: bold;
	}
	.tui-set-row.tui-row-sel .tui-sval.val-cyan {
		color: #00f5d4 !important;
	}

	/* Help / status footers */
	.tui-statusbar {
		color: #718096;
		font-style: italic;
		font-size: 0.78rem;
		padding-top: 0.5rem;
		font-family: var(--font-mono);
	}
	/* Kbd hints */
	.kbd {
		display: inline-block;
		background: rgba(255,255,255,0.08);
		border: 1px solid rgba(255,255,255,0.15);
		border-radius: 4px;
		padding: 0.1rem 0.35rem;
		font-family: var(--font-mono);
		font-size: 0.78em;
		color: rgba(255,255,255,0.7);
	}
	.tui-demo-hint {
		text-align: center;
		margin-top: 1rem;
		font-family: var(--font-mono);
		font-size: 0.72rem;
		color: rgba(255,255,255,0.25);
		letter-spacing: 0.04em;
	}

	.screenshot-section {
		padding: 6rem 0;
	}
	.section-tag {
		display: inline-block;
		font-family: var(--font-mono);
		font-size: 0.7rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--accent);
		background: rgba(139,124,248,0.08);
		border: 1px solid rgba(139,124,248,0.2);
		padding: 0.3rem 0.8rem;
		border-radius: 100px;
		margin-bottom: 1rem;
	}
	.screenshot-hint {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.75rem;
		margin-top: 1.25rem;
		font-family: var(--font-mono);
		font-size: 0.7rem;
		color: rgba(255,255,255,0.25);
		letter-spacing: 0.06em;
	}
	.hint-dot {
		width: 3px;
		height: 3px;
		border-radius: 50%;
		background: rgba(255,255,255,0.2);
	}

	/* Pro license coming soon */
	.pricing-card--coming-soon {
		position: relative;
		overflow: hidden;
		filter: brightness(0.55) saturate(0.5);
		pointer-events: none;
		transition: filter 0.3s ease;
	}
	.coming-soon-overlay {
		position: absolute;
		inset: 0;
		z-index: 10;
		display: flex;
		align-items: flex-start;
		justify-content: flex-end;
		padding: 1rem;
		pointer-events: none;
	}
	.coming-soon-tag {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		background: rgba(139,124,248,0.15);
		border: 1px solid rgba(139,124,248,0.35);
		color: #a99ef8;
		font-family: var(--font-mono);
		font-size: 0.72rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		padding: 0.3rem 0.75rem;
		border-radius: 100px;
		font-weight: 600;
		backdrop-filter: blur(8px);
	}

	/* Nav active state */
	.nav-link.nav-active {
		color: var(--text-primary);
		background: rgba(139,124,248,0.08);
	}

	/* Enhanced back-to-top */
	.back-to-top:hover {
		color: var(--accent);
		border-color: rgba(139,124,248,0.5);
		box-shadow: 0 0 20px rgba(139,124,248,0.2), 0 8px 24px rgba(0,0,0,0.4);
		transform: translateY(-4px) scale(1.05);
	}
	.back-to-top:active {
		transform: translateY(-1px) scale(1.02);
	}
</style>

<script>
	// Terminal typing simulation
	const commands = [
		{ text: "postctl import ./posts", output: "Importing posts from ./posts...\n✔ post-1.md -> Loaded successfully (5 tweets, 2 images)\n✔ post-2.md -> Loaded successfully (Single post)\n✔ post-3.md -> Loaded successfully (Single post)\n\nImport complete. 3 draft posts saved to SQLite store." },
		{ text: "postctl campaign post launch-v1 --dry-run", output: "[DRY RUN] Validating campaign 'launch-v1'...\n✔ Character validation passed (all segments < 280 chars)\n✔ Local image paths exist\n\n[DRY RUN] Posting 'launch-v1-twitter' to Twitter... Success (ID: MockTweetId)\n[DRY RUN] Posting 'launch-v1-linkedin' to LinkedIn... Success (ID: MockLinkedInId)\n\nSimulated run complete. No write actions performed." }
	];

	let commandIndex = 0;
	let charIndex = 0;
	const typingSpeed = 60;
	const delayBetweenCommands = 5000;

	const typedTextEl = document.querySelector("#typing-terminal .typed-text");
	const outputEl = document.querySelector("#typing-terminal .terminal-output");

	function typeCommand() {
		if (!typedTextEl || !outputEl) return;
		const currentCommand = commands[commandIndex];

		if (charIndex < currentCommand.text.length) {
			typedTextEl.textContent += currentCommand.text.charAt(charIndex);
			charIndex++;
			setTimeout(typeCommand, typingSpeed);
		} else {
			// Done typing, show output
			outputEl.textContent = currentCommand.output;
			outputEl.classList.remove("hide");

			// Prepare next command
			setTimeout(() => {
				charIndex = 0;
				commandIndex = (commandIndex + 1) % commands.length;
				typedTextEl.textContent = "";
				outputEl.classList.add("hide");
				outputEl.textContent = "";
				setTimeout(typeCommand, 1000);
			}, delayBetweenCommands);
		}
	}

	// ── Interactive TUI Demo ──────────────────────────────────
	const tuiWindow = document.getElementById('tui-window');
	const tuiTabBtns = document.querySelectorAll('.tui-tab-btn');
	const tuiPanels = document.querySelectorAll('.tui-panel');

	const tabOrder = ['dashboard', 'posts', 'schedule', 'history', 'settings'];
	let currentTab = 0;
	let isPromptActive = false;
	let promptCursor = 0;

	function switchTab(idx: number) {
		currentTab = (idx + tabOrder.length) % tabOrder.length;
		const tabName = tabOrder[currentTab];
		tuiTabBtns.forEach((b, i) => b.classList.toggle('active', i === currentTab));
		tuiPanels.forEach(p => p.classList.toggle('active', p.id === `panel-${tabName}`));
	}

	tuiTabBtns.forEach((btn, i) => {
		btn.addEventListener('click', () => switchTab(i));
	});

	// Keyboard navigation when window is focused
	tuiWindow?.addEventListener('keydown', (e) => {
		const key = (e as KeyboardEvent).key;
		
		if (isPromptActive) {
			e.preventDefault();
			if (key === 'Escape') {
				closeTwitterPrompt();
			} else if (key === 'ArrowUp' || key === 'ArrowDown') {
				movePromptCursor(key === 'ArrowDown' ? 1 : -1);
			} else if (key === 'Enter') {
				confirmTwitterPrompt();
			}
			return;
		}

		if (key === 'Tab') {
			e.preventDefault();
			switchTab(currentTab + ((e as KeyboardEvent).shiftKey ? -1 : 1));
		} else if (key === 'ArrowLeft') {
			e.preventDefault(); switchTab(currentTab - 1);
		} else if (key === 'ArrowRight') {
			e.preventDefault(); switchTab(currentTab + 1);
		} else if (key === 'ArrowUp' || key === 'ArrowDown') {
			e.preventDefault();
			moveRowCursor(key === 'ArrowDown' ? 1 : -1);
		} else if (key === 'Enter') {
			e.preventDefault();
			handleEnter();
		}
	});

	// Click the window to focus it
	tuiWindow?.addEventListener('click', () => tuiWindow.focus());

	// Row cursor movement per panel
	const panelCursors: Record<string, number> = {
		dashboard: 0, posts: 0, schedule: 0, history: 2, settings: 0
	};

	function getSelectableRows(panelId: string): NodeListOf<Element> {
		const panel = document.getElementById(`panel-${panelId}`);
		return panel?.querySelectorAll('.tui-campaign-item[class*="tui-row-sel"], .tui-post-item, .tui-hist-row, .tui-set-row') 
			?? document.querySelectorAll('.__none__');
	}

	function moveRowCursor(delta: number) {
		const tab = tabOrder[currentTab];
		const panel = document.getElementById(`panel-${tab}`);
		if (!panel) return;

		// Get navigable items
		let items: NodeListOf<Element> | null = null;
		if (tab === 'dashboard') items = panel.querySelectorAll('.tui-campaign-item');
		else if (tab === 'posts') items = panel.querySelectorAll('.tui-post-item');
		else if (tab === 'schedule') items = panel.querySelectorAll('.tui-sch-item');
		else if (tab === 'history') items = panel.querySelectorAll('.tui-hist-row');
		else if (tab === 'settings') items = panel.querySelectorAll('.tui-set-row');
		else return;

		if (!items || items.length === 0) return;

		// Remove current selection
		items.forEach(item => {
			item.classList.remove('tui-row-sel');
			const arr = item.querySelector('.tui-arr');
			if (arr) arr.classList.add('tui-arr-h');
		});

		panelCursors[tab] = Math.max(0, Math.min(items.length - 1, panelCursors[tab] + delta));
		const selected = items[panelCursors[tab]];
		selected.classList.add('tui-row-sel');
		const arr = selected.querySelector('.tui-arr');
		if (arr) arr.classList.remove('tui-arr-h');
	}

	function openTwitterPrompt() {
		const prompt = document.getElementById('twitter-prompt');
		if (prompt) {
			prompt.style.display = 'block';
			isPromptActive = true;
			promptCursor = 0;
			updatePromptUI();
		}
	}

	function closeTwitterPrompt() {
		const prompt = document.getElementById('twitter-prompt');
		if (prompt) {
			prompt.style.display = 'none';
			isPromptActive = false;
		}
	}

	function movePromptCursor(delta: number) {
		promptCursor = (promptCursor + delta + 2) % 2;
		updatePromptUI();
	}

	function updatePromptUI() {
		const opts = document.querySelectorAll('#twitter-prompt .tui-prompt-opt');
		opts.forEach((opt, idx) => {
			const arr = opt.querySelector('.tui-arr');
			if (idx === promptCursor) {
				opt.classList.add('tui-row-sel');
				opt.setAttribute('style', 'color: #00f5d4; font-weight: bold; cursor: pointer; padding: 0.1rem 0.4rem; border-radius: 2px;');
				arr?.classList.remove('tui-arr-h');
			} else {
				opt.classList.remove('tui-row-sel');
				opt.setAttribute('style', 'color: #ecc94b; cursor: pointer; padding: 0.1rem 0.4rem; border-radius: 2px;');
				arr?.classList.add('tui-arr-h');
			}
		});
	}

	function confirmTwitterPrompt() {
		const twitterVal = document.getElementById('twitter-val');
		if (twitterVal) {
			if (promptCursor === 0) {
				twitterVal.textContent = 'Connected (API) ✓';
				twitterVal.className = 'tui-sval val-green';
			} else {
				twitterVal.textContent = 'Connected (Cookie) ✓';
				twitterVal.className = 'tui-sval val-cyan';
			}
		}
		closeTwitterPrompt();
	}

	function handleEnter() {
		const tab = tabOrder[currentTab];
		if (tab === 'settings') {
			if (panelCursors.settings === 2) {
				// Toggle dry run
				const dryrunVal = document.getElementById('dryrun-val');
				if (dryrunVal) {
					const isDry = dryrunVal.textContent === 'true';
					dryrunVal.textContent = isDry ? 'false' : 'true';
					dryrunVal.className = isDry ? 'tui-sval tui-warn' : 'tui-sval tui-ok';
				}
			} else if (panelCursors.settings === 5) {
				openTwitterPrompt();
			}
		}
	}

	// Daemon counter countdown on schedule tab
	let daemonCount = 28;
	setInterval(() => {
		const el = document.getElementById('daemon-counter');
		if (el) {
			daemonCount = daemonCount <= 1 ? 30 : daemonCount - 1;
			el.textContent = String(daemonCount);
		}
	}, 1000);

	// ── Back to top ──────────────────────────────────────────
	const backToTopBtn = document.getElementById('back-to-top');

	function smoothScrollTo(targetY: number, duration: number = 600) {
		const startY = window.scrollY;
		const diff = targetY - startY;
		let startTime: number | null = null;

		function ease(t: number) {
			return t < 0.5 ? 4 * t * t * t : 1 - Math.pow(-2 * t + 2, 3) / 2;
		}

		function step(now: number) {
			if (!startTime) startTime = now;
			const elapsed = now - startTime;
			const progress = Math.min(elapsed / duration, 1);
			window.scrollTo(0, startY + diff * ease(progress));
			if (progress < 1) requestAnimationFrame(step);
		}
		requestAnimationFrame(step);
	}

	window.addEventListener('scroll', () => {
		if (window.scrollY > 400) {
			backToTopBtn?.classList.add('visible');
		} else {
			backToTopBtn?.classList.remove('visible');
		}
		updateActiveNav();
	}, { passive: true });

	backToTopBtn?.addEventListener('click', () => {
		backToTopBtn.style.transform = 'scale(0.92)';
		setTimeout(() => { backToTopBtn.style.transform = ''; }, 150);
		smoothScrollTo(0, 700);
	});

	// ── Smooth anchor scroll ──────────────────────────────────
	document.querySelectorAll('a[href^="#"]').forEach(anchor => {
		anchor.addEventListener('click', function (e) {
			e.preventDefault();
			const href = (this as HTMLAnchorElement).getAttribute('href');
			if (!href || href === '#') return;
			const target = document.querySelector(href) as HTMLElement;
			if (!target) return;
			const headerOffset = 90;
			const targetY = target.getBoundingClientRect().top + window.scrollY - headerOffset;
			smoothScrollTo(targetY, 800);
		});
	});

	// ── Nav active state on scroll ────────────────────────────
	const navLinks = document.querySelectorAll('.nav-link[href^="#"]');
	const sections = Array.from(navLinks).map(l => {
		const id = (l as HTMLAnchorElement).getAttribute('href')?.slice(1);
		return id ? document.getElementById(id) : null;
	});

	function updateActiveNav() {
		const scrollMid = window.scrollY + window.innerHeight * 0.4;
		let active = -1;
		sections.forEach((sec, i) => {
			if (sec && sec.offsetTop <= scrollMid) active = i;
		});
		navLinks.forEach((l, i) => {
			l.classList.toggle('nav-active', i === active);
		});
	}
	updateActiveNav();

	// ── Scroll reveal ─────────────────────────────────────────
	const revealTargets = document.querySelectorAll(
		'.feature-card, .how-step-card, .ai-workflow-card, .pricing-card, .section-header, .tui-window, .donate-banner, .carousel-root, .screenshot-hint, .tui-demo-hint'
	);

	const revealObserver = new IntersectionObserver((entries, observer) => {
		entries.forEach((entry, idx) => {
			if (entry.isIntersecting) {
				const el = entry.target as HTMLElement;
				el.style.transitionDelay = `${Math.min(idx * 0.04, 0.25)}s`;
				el.classList.add('active');
				observer.unobserve(el);
			}
		});
	}, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });

	revealTargets.forEach(el => {
		el.classList.add('reveal');
		revealObserver.observe(el);
	});

	// ── Start typing simulator ────────────────────────────────
	window.addEventListener('DOMContentLoaded', () => {
		setTimeout(typeCommand, 1000);
	});
</script>
